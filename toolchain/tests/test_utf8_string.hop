// EXPECT: hello
// EXPECT: 42
// EXPECT: Ω
import String from utf8
import io from linux

entry main {
    String s = String(8)
    s.append(104)
    s.append(101)
    s.append(108)
    s.append(108)
    s.append(111)
    s.append(10)
    write(1, s.ptr(), s.len())

    String n = String(16)
    n.append_int(42)
    n.append(10)
    write(1, n.ptr(), n.len())

    // U+03A9 GREEK CAPITAL LETTER OMEGA — 2-byte UTF-8: 0xCE 0xA9
    String u = String(8)
    u.append(937)
    u.append(10)
    write(1, u.ptr(), u.len())
}
