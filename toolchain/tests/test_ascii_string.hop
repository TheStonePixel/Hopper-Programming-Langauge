// EXPECT: hello
// EXPECT: 42
// EXPECT: ff
// EXPECT: 0
import String from ascii
import io from linux

entry main {
    String s = String(8)
    s.append(104)
    s.append(101)
    s.append(108)
    s.append(108)
    s.append(111)
    s.append(10)
    write(1, s.ptr(), s.len())

    String n = String(16)
    n.append_int(42)
    n.append(10)
    write(1, n.ptr(), n.len())

    String h = String(16)
    h.append_hex(255)
    h.append(10)
    write(1, h.ptr(), h.len())

    String z = String(4)
    z.append_int(0)
    z.append(10)
    write(1, z.ptr(), z.len())
}
