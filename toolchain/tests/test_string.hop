// Tests String<byte> — growable byte string, no libc
// EXPECT: hello
// EXPECT: 42
// EXPECT: ff
// EXPECT: 0

import string from ds

entry main {
    String<byte> s = String(8)
    s.append(104)
    s.append(101)
    s.append(108)
    s.append(108)
    s.append(111)
    s.append(10)
    s.print(1)

    String<byte> n = String(16)
    n.append_int(42)
    n.append(10)
    n.print(1)

    String<byte> h = String(16)
    h.append_hex(255)
    h.append(10)
    h.print(1)

    String<byte> z = String(4)
    z.append_int(0)
    z.append(10)
    z.print(1)
}
