// ── format: reformat source files via the AST ─────────────────────────────

function formatNode(node, indent) {
    // Minimal formatter — emits canonical Hopper source from the AST.
    // Handles the most common statement and expression forms.
    const I = "    ".repeat(indent);
    const I1 = "    ".repeat(indent + 1);

    function fmtType(t) { return t; }
    function fmtExpr(e) {
        if (!e) return "";
        switch (e.kind) {
            case "Int":
            case "IntLiteral":   return String(e.value);
            case "Float":
            case "FloatLiteral": return String(e.value);
            case "Bool":
            case "BoolLiteral":  return String(e.value);
            case "Str":
            case "StringLiteral": return `"${e.value.replace(/\\/g, "\\\\").replace(/"/g, '\\"').replace(/\n/g, "\\n")}"`;
            case "Char":
            case "CharLiteral":  return `'${e.value}'`;
            case "Null":     return "null";
            case "Var":      return e.name;
            case "Self":     return "self";
            case "CastExpr": return `cast ${fmtExpr(e.expr)}`;
            case "Deref":    return `${fmtExpr(e.expr)}::value`;
            case "AddressOf": return `${e.name}::address`;
            case "FieldAccess": return `${e.object}.${e.field}`;
            case "Unary":    return `${e.op}${fmtExpr(e.operand)}`;
            case "Binary":   return `${fmtExpr(e.left)} ${e.op} ${fmtExpr(e.right)}`;
            case "Call":     return `${e.callee}(${(e.args || []).map(fmtExpr).join(", ")})`;
            case "MethodCall": return `${e.object}.${e.method}(${(e.args || []).map(fmtExpr).join(", ")})`;
            case "ChainedMethodCall": return `${fmtExpr(e.receiver)}.${e.method}(${(e.args || []).map(fmtExpr).join(", ")})`;
            case "ArrayAccess": return `${e.name}[${fmtExpr(e.index)}]`;
            case "New":      return `new ${e.type}(${(e.args || []).map(fmtExpr).join(", ")})`;
            case "SizeOf":   return `sizeof(${e.type})`;
            default:         return `/* ${e.kind} */`;
        }
    }
    function fmtStmts(stmts, ind) {
        return (stmts || []).map(s => fmtStmt(s, ind)).join("\n");
    }
    function fmtStmt(s, ind) {
        const Pi  = "    ".repeat(ind);
        const Pi1 = "    ".repeat(ind + 1);
        if (!s) return "";
        switch (s.kind) {
            case "VarDecl":
                return s.init
                    ? `${Pi}${fmtType(s.type)} ${s.name} = ${fmtExpr(s.init)}`
                    : `${Pi}${fmtType(s.type)} ${s.name}`;
            case "AssignStmt":
            case "Assign":
                return `${Pi}${fmtExpr(s.target || s.lhs)} = ${fmtExpr(s.value || s.rhs)}`;
            case "ExprStmt":
                return `${Pi}${fmtExpr(s.expr)}`;
            case "ReturnStmt":
            case "Return":
                return s.expr ? `${Pi}return ${fmtExpr(s.expr)}` : `${Pi}return`;
            case "IfStmt":
            case "If": {
                const cond = s.cond || s.condition;
                const then_ = getStmts(s.thenBlock || s.then);
                const else_ = getStmts(s.elseBlock || s.else_);
                let out = `${Pi}if (${fmtExpr(cond)}) {\n${fmtStmts(then_, ind + 1)}\n${Pi}}`;
                if (else_.length) out += ` else {\n${fmtStmts(else_, ind + 1)}\n${Pi}}`;
                return out;
            }
            case "WhileStmt":
            case "While": {
                const cond = s.cond || s.condition;
                return `${Pi}while (${fmtExpr(cond)}) {\n${fmtStmts(getStmts(s.body), ind + 1)}\n${Pi}}`;
            }
            case "ForStmt":
            case "For":
                return `${Pi}for (${fmtStmt(s.init, 0).trim()}; ${fmtExpr(s.cond || s.condition)}; ${fmtStmt(s.update, 0).trim()}) {\n${fmtStmts(getStmts(s.body), ind + 1)}\n${Pi}}`;
            case "BreakStmt":
            case "Break":    return `${Pi}break`;
            case "ContinueStmt":
            case "Continue": return `${Pi}continue`;
            case "Defer":    return `${Pi}defer ${fmtStmt(s.stmt, 0).trim()}`;
            default:         return `${Pi}/* ${s.kind} */`;
        }
    }
    return fmtStmt(node, indent);
}

function formatSource(ast, originalSource) {
    return formatAst(ast, originalSource);
}

function _legacyFormatSource(ast, originalSource) {
    // Reconstruct imports from the original source (they're stripped before AST build)
    const importLines = [];
    for (const line of originalSource.split("\n")) {
        if (/^\s*import\s+/.test(line)) importLines.push(line.trim());
    }

    const parts = [];
    if (importLines.length) parts.push(importLines.join("\n") + "\n");

    for (const c of (ast.consts || [])) {
        parts.push(`const ${c.type} ${c.name} = ${c.value}`);
    }

    for (const fn of (ast.functions || [])) {
        if (fn.isBuiltin || fn.isImported || fn.isExtern) continue;
        const params = (fn.params || []).map(p => `${p.type} ${p.name}`).join(", ");
        const ret    = fn.returnType ? ` ${fn.returnType}` : "";
        const body   = getStmts(fn.body).map(s => formatNode(s, 1)).join("\n");
        parts.push(`function ${fn.name}(${params})${ret} {\n${body}\n}`);
    }

    for (const cls of (ast.classes || [])) {
        if (cls.isBuiltin) continue;
        const lines = [`class ${cls.name} {`];
        for (const f of (cls.fields || [])) lines.push(`    ${f.type} ${f.name}`);
        if (cls.constructor) {
            const params = (cls.constructor.params || []).map(p => `${p.type} ${p.name}`).join(", ");
            const body   = getStmts(cls.constructor.body).map(s => formatNode(s, 2)).join("\n");
            lines.push(`\n    constructor(${params}) {\n${body}\n    }`);
        }
        for (const m of (cls.methods || [])) {
            const params  = (m.params || []).map(p => `${p.type} ${p.name}`).join(", ");
            const ret     = m.returnType ? ` ${m.returnType}` : "";
            const body    = getStmts(m.body).map(s => formatNode(s, 2)).join("\n");
            lines.push(`\n    function ${m.name}(${params})${ret} {\n${body}\n    }`);
        }
        if (cls.destructor) {
            const body = getStmts(cls.destructor.body).map(s => formatNode(s, 2)).join("\n");
            lines.push(`\n    destructor() {\n${body}\n    }`);
        }
        lines.push("}");
        parts.push(lines.join("\n"));
    }

    if (ast.entry) {
        const params = (ast.entry.params || []).map(p => `${p.type} ${p.name}`).join(", ");
        const body   = getStmts(ast.entry.body).map(s => formatNode(s, 1)).join("\n");
        const sig    = params.length ? `(${params})` : "";
        parts.push(`entry ${ast.entry.name}${sig} {\n${body}\n}`);
    }

    return parts.join("\n\n") + "\n";
}

function cmdFormat(args) {
    const inPlace = args.includes("--write") || args.includes("-w");
    const files   = args.filter(a => a.endsWith(".hop"));

    if (files.length === 0) {
        console.error("hopper: format requires at least one .hop file");
        process.exit(1);
    }

    for (const file of files) {
        if (!fs.existsSync(file)) {
            console.error(`hopper: file not found: ${file}`);
            process.exit(1);
        }
        const src = fs.readFileSync(file, "utf8");
        const ast = buildAstFromSource(src, { sourceFile: path.resolve(file) });
        const formatted = formatSource(ast, src);
        if (inPlace) {
            fs.writeFileSync(file, formatted, "utf8");
            console.log(`formatted: ${file}`);
        } else {
            process.stdout.write(formatted);
        }
    }
}

function cmdIR(args) {
    if (!args[0]) { console.error("hopper: ir requires a file"); process.exit(1); }
    console.log(toIR(args[0]));
}

function cmdAST(args) {
    if (!args[0]) { console.error("hopper: ast requires a file"); process.exit(1); }
    const abs      = path.resolve(args[0]);
    const bindings = loadBindings(abs, "host");
    const resolved = resolveAllImports(abs, bindings);
    const ast      = buildAstFromFiles(resolved);
    console.log(JSON.stringify(ast, null, 2));
}

function cmdParse(args) {
    if (!args[0]) { console.error("hopper: parse requires a file"); process.exit(1); }
    const src = fs.readFileSync(args[0], "utf8");
    const { parser, tree } = parseSource(src);
    console.log(tree.toStringTree(parser.ruleNames));
}

function cmdTest(args) {
    const depsFlag  = args.includes("--deps");
    const rest      = args.filter(a => a !== "--deps");
    const extraArgs = depsFlag ? ["--deps"] : [];

    // If the first positional arg is a module name, pass it through directly.
    // Otherwise auto-detect the nearest project root from CWD so tests are
    // scoped to whatever module the user is working in.
    const nameArg = rest.find(a => !a.startsWith("-"));
    if (!nameArg) {
        const projectRoot = findProjectRoot(process.cwd());
        if (fs.existsSync(path.join(projectRoot, "hopper.json"))) {
            extraArgs.push(`--root=${projectRoot}`);
        }
    }

    const testScript = path.join(__dirname, "tools", "test.js");
    const allArgs    = [...rest, ...extraArgs].map(a => `"${a}"`).join(" ");
    execSync(`node "${testScript}" ${allArgs}`, { stdio: "inherit" });
}

// ── flash ──────────────────────────────────────────────────────────────────

function cmdFlash(args) {
    // ── parse flags ───────────────────────────────────────────────────────
    let mountArg = null;
    let dryRun   = false;
    let profile  = "dev";
    for (let i = 0; i < args.length; i++) {
        if (args[i] === "--mount" || args[i] === "-m")  { mountArg = args[++i]; continue; }
        if (args[i].startsWith("--mount="))             { mountArg = args[i].slice(8); continue; }
        if (args[i] === "--dry-run")                    { dryRun   = true; continue; }
        if (args[i] === "--production")                 { profile  = "production"; continue; }
    }

    // ── load project ──────────────────────────────────────────────────────
    const projectRoot = findProjectRoot(process.cwd());
    const manifest    = readManifestAt(projectRoot);
    const boardName   = manifest.board;

    if (!boardName) {
        console.error("hopper: 'board' is not set in hopper.json — flash only works for bare-metal targets");
        process.exit(1);
    }

    const boardCfg = BOARD_CONFIGS[boardName];
    if (!boardCfg?.flash) {
        console.error(`hopper: board '${boardName}' does not have a flash configuration`);
        process.exit(1);
    }

    const flashCfg = boardCfg.flash;

    // ── QEMU: launch emulator directly ────────────────────────────────────
    if (flashCfg.method === "qemu") {
        const qemuCfg  = boardCfg.qemu;
        const name     = manifest.name || "project";
        const buildDir = path.join(projectRoot, "build");
        const elfPath  = path.join(buildDir, `${name}.elf`);
        if (!fs.existsSync(elfPath)) {
            console.error(`hopper: ${name}.elf not found — run 'hopper build' first`);
            process.exit(1);
        }
        const extraArgs = (qemuCfg.args || []).join(" ");
        const cmd = `${qemuCfg.binary} -M ${qemuCfg.machine} -cpu ${qemuCfg.cpu} -kernel "${elfPath}" ${extraArgs}`.trim();
        console.error(`hopper: launching QEMU  [${boardName}]`);
        console.error(`  ${cmd}`);
        if (!dryRun) execSync(cmd, { stdio: "inherit" });
        return;
    }

    // ── locate built binary ───────────────────────────────────────────────
    const buildDir  = path.join(projectRoot, "build");
    const imgPath   = path.join(buildDir, flashCfg.outputFile);
    const name      = manifest.name || "project";
    const metaPath  = path.join(buildDir, `${name}.meta.json`);

    if (!fs.existsSync(imgPath)) {
        console.error([
            `hopper: ${flashCfg.outputFile} not found at ${buildDir}`,
            `  Run 'hopper build' first.`,
        ].join("\n"));
        process.exit(1);
    }

    // ── read build metadata ───────────────────────────────────────────────
    let meta = null;
    if (fs.existsSync(metaPath)) {
        try { meta = JSON.parse(fs.readFileSync(metaPath, "utf8")); } catch {}
    }

    // ── find the SD card ──────────────────────────────────────────────────
    const mountOverride = mountArg || manifest.flash?.mount || null;
    let mountPoint = mountOverride;

    if (!mountPoint) {
        mountPoint = detectSdCard(flashCfg);
        if (!mountPoint) {
            console.error([
                `hopper: could not auto-detect an SD card with ${flashCfg.requiredFirmware[0]}.`,
                ``,
                `  Make sure the card is mounted, then try again.`,
                `  Or specify the path explicitly:`,
                `    hopper flash --mount /path/to/sdcard`,
                ``,
                `  The SD card needs the Pi Zero firmware blobs in its root:`,
                `    bootcode.bin  start.elf`,
                `  Download from: https://github.com/raspberrypi/firmware/tree/master/boot`,
            ].join("\n"));
            process.exit(1);
        }
    }

    // ── verify required firmware blobs ────────────────────────────────────
    const missing = flashCfg.requiredFirmware.filter(f => !fs.existsSync(path.join(mountPoint, f)));
    if (missing.length) {
        console.error([
            `hopper: missing firmware on SD card at ${mountPoint}:`,
            ...missing.map(f => `  ✗  ${f}`),
            ``,
            `  Download from: https://github.com/raspberrypi/firmware/tree/master/boot`,
            `  Copy the missing files to the SD card root and try again.`,
        ].join("\n"));
        process.exit(1);
    }

    // ── print summary ─────────────────────────────────────────────────────
    const imgSize = fs.statSync(imgPath).size;
    const arch    = meta?.arch    ?? boardCfg.meta?.arch    ?? "unknown";
    const endian  = meta?.endian  ?? boardCfg.meta?.endian  ?? "unknown";
    const bits    = meta?.bits    ?? boardCfg.meta?.bits    ?? "?";
    const loadAt  = meta?.loadAddress ?? boardCfg.meta?.loadAddress ?? "?";

    console.log(`\nhopper: flash  ${name}  →  ${mountPoint}`);
    console.log(`  board     ${boardName}  (${arch} ${endian}-endian ${bits}-bit, load ${loadAt})`);
    if (meta?.builtAt) {
        const when = new Date(meta.builtAt).toLocaleString();
        console.log(`  built     ${when}`);
    }
    console.log(`  image     ${flashCfg.outputFile}  (${(imgSize / 1024).toFixed(1)} KB)`);
    for (const f of flashCfg.requiredFirmware) {
        console.log(`  found     ${f} ✓`);
    }

    if (dryRun) {
        console.log(`\n  [dry run — nothing written]\n`);
        return;
    }

    // ── copy kernel image ─────────────────────────────────────────────────
    const destImg = path.join(mountPoint, flashCfg.outputFile);
    fs.copyFileSync(imgPath, destImg);
    console.log(`  wrote     ${flashCfg.outputFile}`);

    // ── ensure config.txt has required lines ──────────────────────────────
    if (flashCfg.configLines?.length) {
        const cfgPath = path.join(mountPoint, "config.txt");
        const added   = ensureConfigLines(cfgPath, flashCfg.configLines);
        if (added > 0) {
            console.log(`  wrote     config.txt  (+${added} line${added > 1 ? "s" : ""})`);
        } else {
            console.log(`  config.txt already up to date ✓`);
        }
    }

    // ── sync ─────────────────────────────────────────────────────────────
    try { execSync("sync", { stdio: "ignore" }); } catch {}
    console.log(`\nhopper: done — remove SD card safely, insert in Pi Zero, power on\n`);
}

// ── fix: validate and auto-repair a project ───────────────────────────────

function cmdFix(args) {
    const G = "\x1b[32m", R = "\x1b[31m", Y = "\x1b[33m";
    const DIM = "\x1b[2m", BOLD = "\x1b[1m", RST = "\x1b[0m";
    const TICK = "✓", CROSS = "✗";

    const dryRun    = args.includes("--dry-run") || args.includes("-n");
    const pathArg   = args.find(a => !a.startsWith("-"));
    const projectRoot = pathArg
        ? path.resolve(pathArg)
        : findProjectRoot(process.cwd());

    const manifestPath = path.join(projectRoot, "hopper.json");
    if (!fs.existsSync(manifestPath)) {
        console.error(`hopper fix: no hopper.json found in ${projectRoot}`);
        process.exit(1);
    }

    let manifest;
    try {
        manifest = JSON.parse(fs.readFileSync(manifestPath, "utf8"));
    } catch (e) {
        console.error(`hopper fix: malformed hopper.json — ${e.message}`);
        console.error(`  ${CROSS}  manual fix required: repair JSON syntax`);
        process.exit(1);
    }

    const fixes  = [];
    const manual = [];
    let   manifestDirty = false;

    const isLib  = manifest.type === "library";

    // ── 1. Standard directories ──────────────────────────────────────────
    const standardDirs = ["src", "tests"];
    if (isLib) standardDirs.push("contracts");

    for (const d of standardDirs) {
        const dirPath = path.join(projectRoot, d);
        if (!fs.existsSync(dirPath)) {
            if (!dryRun) fs.mkdirSync(dirPath, { recursive: true });
            fixes.push(`created ${d}/`);
        }
    }

    // ── 2. Entry file for executables ────────────────────────────────────
    if (!isLib && manifest.entry) {
        const entryAbs = path.join(projectRoot, manifest.entry);
        if (!fs.existsSync(entryAbs)) {
            if (!dryRun) {
                fs.mkdirSync(path.dirname(entryAbs), { recursive: true });
                fs.writeFileSync(entryAbs, `entry main {\n}\n`, "utf8");
            }
            fixes.push(`created ${manifest.entry}  (stub entry point)`);
        }
    }

    // ── 3. Export files for libraries ────────────────────────────────────
    for (const [exportName, exp] of Object.entries(manifest.exports || {})) {
        const pairs = [
            ["for",  exp.for],
            ["use",  exp.use],
        ];
        for (const [field, relPath] of pairs) {
            if (!relPath) continue;
            const absPath = path.join(projectRoot, relPath);
            if (!fs.existsSync(absPath)) {
                if (!dryRun) {
                    fs.mkdirSync(path.dirname(absPath), { recursive: true });
                    const stub = field === "contract"
                        ? `interface ${exportName} {\n}\n`
                        : `class Standard${exportName} implements ${exportName} {\n    constructor() { }\n    destructor() { }\n}\n`;
                    fs.writeFileSync(absPath, stub, "utf8");
                }
                fixes.push(`created ${relPath}  (stub ${field})`);
            }
        }
    }

    // ── 4. Scan source files for undeclared imports ───────────────────────
    const declaredDeps = new Set(Object.keys(manifest.dependencies || {}));

    // Collect binding-declared module names (from targets) — these don't
    // need a separate entry in dependencies.
    const targetBound = new Set();
    for (const bindings of Object.values(manifest.targets || {})) {
        for (const b of Object.values(bindings || {})) {
            if (b.from) targetBound.add(b.from);
        }
    }

    // All project source files to scan (skip modules/ subdirectory)
    const toScan = new Set();
    for (const subdir of ["src", "contracts"]) {
        const d = path.join(projectRoot, subdir);
        if (fs.existsSync(d)) {
            for (const f of fs.readdirSync(d).filter(x => x.endsWith(".hop")))
                toScan.add(path.join(d, f));
        }
    }
    // Also scan files referenced explicitly in exports and entry
    for (const exp of Object.values(manifest.exports || {})) {
        for (const relPath of [exp.for, exp.use]) {
            if (!relPath) continue;
            const abs = path.join(projectRoot, relPath);
            if (fs.existsSync(abs)) toScan.add(abs);
        }
    }
    if (manifest.entry) {
        const abs = path.join(projectRoot, manifest.entry);
        if (fs.existsSync(abs)) toScan.add(abs);
    }

    const missingDeps = new Map();  // moduleName → Set of importing files
    const importRe = /^[ \t]*import\s+\S+\s+from\s+([a-zA-Z_][a-zA-Z0-9_]*)[ \t]*$/gm;

    for (const filePath of toScan) {
        let content;
        try { content = fs.readFileSync(filePath, "utf8"); } catch { continue; }
        importRe.lastIndex = 0;
        let m;
        while ((m = importRe.exec(content)) !== null) {
            const mod = m[1];
            if (mod === manifest.name)    continue;   // self-import
            if (declaredDeps.has(mod))    continue;   // already declared
            if (targetBound.has(mod))     continue;   // covered by targets
            if (!missingDeps.has(mod)) missingDeps.set(mod, new Set());
            missingDeps.get(mod).add(path.relative(projectRoot, filePath));
        }
    }

    for (const [dep, files] of missingDeps) {
        const modPath = path.join(MODULES_DIR, dep);
        const fileList = [...files].join(", ");
        if (fs.existsSync(modPath)) {
            let version = "0.1.0";
            try {
                const dm = JSON.parse(fs.readFileSync(path.join(modPath, "hopper.json"), "utf8"));
                if (dm.version) version = dm.version;
            } catch {}
            if (!dryRun) {
                if (!manifest.dependencies) manifest.dependencies = {};
                manifest.dependencies[dep] = version;
                declaredDeps.add(dep);
                manifestDirty = true;
            }
            fixes.push(`added dependency "${dep}": "${version}"  (imported in ${fileList})`);
        } else {
            manual.push(`import '${dep}' in ${fileList} — not in module store  →  hopper install ${dep}`);
        }
    }

    if (manifestDirty) {
        fs.writeFileSync(manifestPath, JSON.stringify(manifest, null, 2) + "\n", "utf8");
    }

    // ── Report ─────────────────────────────────────────────────────────────
    const rel = path.relative(process.cwd(), projectRoot) || ".";
    console.log();
    if (fixes.length === 0 && manual.length === 0) {
        console.log(`${G}${TICK}${RST}  ${BOLD}nothing to fix${RST}  ${DIM}${rel}${RST}`);
    } else {
        console.log(`${BOLD}hopper fix${RST}  ${DIM}${rel}${RST}${dryRun ? `  ${Y}[dry run]${RST}` : ""}`);
        if (fixes.length > 0) {
            console.log();
            console.log(`  ${G}Fixed (${fixes.length})${RST}`);
            for (const f of fixes) console.log(`  ${G}${TICK}${RST}  ${f}`);
        }
        if (manual.length > 0) {
            console.log();
            console.log(`  ${Y}Needs manual resolution (${manual.length})${RST}`);
            for (const m of manual) console.log(`  ${R}${CROSS}${RST}  ${m}`);
        }
    }
    console.log();

    if (manual.length > 0) process.exit(1);
}

// ── usage ──────────────────────────────────────────────────────────────────

function usage() {
    console.log([
        "",
        "  Hopper  — systems programming language",
        "",
        "  hopper init <name>                  scaffold a new project",
        "  hopper build [file.hop] [-o out]    compile to executable (default: main.hop)",
        "  hopper build module <name>          scaffold modules/<name>/ with tests/ dir",
        "  hopper run [binary]                 execute a built binary (default: build/<entry>)",
        "  hopper run test [module]            run tests (all, or a specific module)",
        "  hopper flash [--mount <path>]       write bare-metal image to SD card",
        "              [--dry-run]             show what would be flashed without writing",
        "  hopper install [module...]          install packages from stdlib or registry",
        "  hopper uninstall <module...>        remove installed packages",
        "  hopper publish [name]               publish this package to the registry",
        "  hopper revoke [name]                permanently delete a package from the registry",
        "  hopper fix [path] [--dry-run]       auto-repair missing files and undeclared deps",
        "  hopper check [file.hop] [--asan|--tsan|--ubsan|--msan]",
        "                                      compile with sanitizers (default: --asan)",
        "  hopper debug [file.hop]             debug support (coming soon)",
        "  hopper profile [file.hop]           performance profiling (coming soon)",
        "  hopper format [-w] <file.hop...>    reformat source files (-w to edit in place)",
        "  hopper test [module]                run tests (all, or a specific module)",
        "  hopper ir <file.hop>                print LLVM IR",
        "  hopper ast <file.hop>               print AST as JSON",
        "  hopper parse <file.hop>             print parse tree",
        "",
    ].join("\n"));
