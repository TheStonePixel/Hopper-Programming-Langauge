// ── helpers ────────────────────────────────────────────────────────────────

function baseName(file) {
    return path.basename(file, path.extname(file));
}

// Walk up from the source file to find hopper.json; return a Map of target bindings.
function loadBindings(sourceFile, target = "host") {
    let dir = path.dirname(path.resolve(sourceFile));
    while (true) {
        const candidate = path.join(dir, "hopper.json");
        if (fs.existsSync(candidate)) {
            try {
                const config = JSON.parse(fs.readFileSync(candidate, "utf8"));
                const targetBindings = (config.targets || {})[target] || {};
                const bindings = new Map();
                for (const [name, b] of Object.entries(targetBindings)) {
                    if (!b.for || !b.use) {
                        throw new Error(`Binding '${name}' in hopper.json is missing required fields 'for' and 'use'`);
                    }
                    bindings.set(name, {
                        contract:       path.resolve(dir, b.for),
                        implementation: path.resolve(dir, b.use),
                        inline:         b.inline === true,
                    });
                }
                return bindings;
            } catch { /* malformed hopper.json — skip */ }
        }
        const parent = path.dirname(dir);
        if (parent === dir) break;
        dir = parent;
    }
    return new Map();
}

// ── import resolution (build-system side) ──────────────────────────────────

// Extract import statements from source text.
function extractImports(source) {
    const imports = [];
    const re = /^[ \t]*import\s+([A-Za-z_][A-Za-z0-9_]*(?:\s*,\s*[A-Za-z_][A-Za-z0-9_]*)*)\s+from\s+([A-Za-z_][A-Za-z0-9_]*)[ \t]*$/gm;
    let m;
    while ((m = re.exec(source)) !== null) {
        const names = m[1].split(',').map(n => n.trim());
        const mod   = m[2];
        for (const name of names) imports.push({ name, module: mod });
    }
    return imports;
}

// Resolve a single named direct import (no binding) to an absolute file path.
function resolveDirectImport(name, moduleName, fromDir, importingFile) {
    let dir = fromDir;
    while (true) {
        const candidate = path.join(dir, 'modules', moduleName);
        if (fs.existsSync(candidate)) {
            const srcDir  = path.join(candidate, 'src');
            const loadDir = fs.existsSync(srcDir) ? srcDir : candidate;
            // Convention: file named after export
            const byName = path.join(loadDir, name + '.hop');
            if (fs.existsSync(byName)) return byName;
            // Scan for declaration
            const allFiles = fs.existsSync(loadDir)
                ? fs.readdirSync(loadDir).filter(f => f.endsWith('.hop')).map(f => path.join(loadDir, f))
                : [];
            const pat = new RegExp(`^\\s*(interface|class|function|enum|template)\\s+${name}\\b`, 'm');
            const matches = allFiles.filter(f => pat.test(fs.readFileSync(f, 'utf8')));
            const sf = importingFile ? ` (imported from ${path.basename(importingFile)})` : '';
            if (matches.length === 0)
                throw new Error(`No export named '${name}' found in module '${moduleName}'${sf}\n  Looked in: ${loadDir}\n  Available: ${allFiles.map(f => path.basename(f)).join(', ') || '(none)'}`);
            if (matches.length > 1)
                throw new Error(`Ambiguous import: '${name}' declared in multiple files in module '${moduleName}'${sf}\n  Matches: ${matches.map(f => path.basename(f)).join(', ')}\n  Rename one or add a binding in hopper.json`);
            return matches[0];
        }
        const parent = path.dirname(dir);
        if (parent === dir) break;
        dir = parent;
    }
    const sf = importingFile ? ` (imported from ${path.basename(importingFile)})` : '';
    throw new Error(`Module '${moduleName}' not found${sf}\n  Run: hopper install ${moduleName}`);
}

// Recursively resolve all imports for an entry file.
// Returns ordered array (dependencies first, entry last):
//   { path, inline, role: 'interface'|'implementation'|'source', bindingName? }
function resolveAllImports(entryFile, bindings) {
    const visited = new Set();
    const ordered = [];

    function visit(filePath, inline = false, role = 'source', bindingName = null) {
        if (visited.has(filePath)) return;
        visited.add(filePath);

        const source   = fs.readFileSync(filePath, 'utf8');
        const imports  = extractImports(source);
        const fileDir  = path.dirname(filePath);

        for (const { name, module: mod } of imports) {
            if (bindings && bindings.has(name)) {
                const b = bindings.get(name);
                if (!fs.existsSync(b.contract))
                    throw new Error(`Interface file not found for '${name}' (imported from ${path.basename(filePath)})\n  'for': ${b.contract}\n  Check the 'for' path in hopper.json`);
                if (!fs.existsSync(b.implementation))
                    throw new Error(`Implementation file not found for '${name}' (imported from ${path.basename(filePath)})\n  'use': ${b.implementation}\n  Check the 'use' path in hopper.json`);
                visit(b.contract,       false,    'interface',      name);
                visit(b.implementation, b.inline, 'implementation', name);
            } else {
                const resolved = resolveDirectImport(name, mod, fileDir, filePath);
                visit(resolved);
            }
        }

        ordered.push({ path: filePath, inline, role, bindingName });
    }

    visit(entryFile);
    return ordered;
}

function toIR(file, target = "host") {
    const abs      = path.resolve(file);
    const bindings = loadBindings(abs, target);
    const resolved = resolveAllImports(abs, bindings);
    const ast      = buildAstFromFiles(resolved);
    return genModule(ast, { target });
}

// Walk up from startDir to find the nearest directory containing hopper.json.
// Falls back to startDir itself if none is found.
function findProjectRoot(startDir) {
    let cursor = path.resolve(startDir);
    while (true) {
        if (fs.existsSync(path.join(cursor, "hopper.json"))) return cursor;
        const parent = path.dirname(cursor);
        if (parent === cursor) return path.resolve(startDir);
        cursor = parent;
    }
}

// Returns { projectRoot, buildDir, llDir, oDir } for the given entry file.
// Executables land directly in build/; intermediates go in build/ll/ and build/o/.
function profileDirs(entryFile, _profile) {
    const projectRoot = findProjectRoot(path.dirname(path.resolve(entryFile)));
    const buildDir    = path.join(projectRoot, "build");
    const llDir       = path.join(buildDir, "ll");
    const oDir        = path.join(buildDir, "o");
    fs.mkdirSync(llDir, { recursive: true });
    fs.mkdirSync(oDir,  { recursive: true });
    return { projectRoot, buildDir, llDir, oDir };
}

// Clang flags per build profile.
function clangFlags(profile) {
    if (profile === "production") return "-O2 -c -fPIC -Wno-override-module";
    return "-g -O0 -c -fPIC -Wno-override-module"; // dev and test
}

