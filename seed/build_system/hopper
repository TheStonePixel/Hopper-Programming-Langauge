#!/usr/bin/env node
import fs from "node:fs";
import path from "node:path";
import https from "node:https";
import readline from "node:readline";
import { fileURLToPath } from "node:url";
import { execSync, spawn } from "node:child_process";
import { buildAstFromSource } from "../compiler/src/astBuilder.js";
import { genModule } from "../compiler/src/codegenLLVM.js";
import { parseSource } from "../compiler/src/parse.js";
import { formatAst } from "../compiler/src/formatter.js";

const __filename  = fileURLToPath(import.meta.url);
const __dirname   = path.dirname(__filename);
const ROOT        = path.resolve(__dirname, "..", "..");
const MODULES_DIR = path.join(ROOT, "hopper", "modules");

// ── registry ───────────────────────────────────────────────────────────────
const REGISTRY_ORG = "HopperLangauge";               // github.com/HopperLangauge/<pkg>
const REGISTRY_URL = `https://github.com/${REGISTRY_ORG}`;  // swap for thestonepixel.com/hopper later

// ── helpers ────────────────────────────────────────────────────────────────

function baseName(file) {
    return path.basename(file, path.extname(file));
}

// Walk up from the source file to find hopper.json; return a Map of target bindings.
function loadBindings(sourceFile, target = "host") {
    let dir = path.dirname(path.resolve(sourceFile));
    while (true) {
        const candidate = path.join(dir, "hopper.json");
        if (fs.existsSync(candidate)) {
            try {
                const config = JSON.parse(fs.readFileSync(candidate, "utf8"));
                const targetBindings = (config.targets || {})[target] || {};
                const bindings = new Map();
                for (const [name, b] of Object.entries(targetBindings)) {
                    bindings.set(name, {
                        from:           b.from || null,
                        interface:      path.resolve(dir, b.interface),
                        implementation: path.resolve(dir, b.implementation),
                    });
                }
                return bindings;
            } catch { /* malformed hopper.json — skip */ }
        }
        const parent = path.dirname(dir);
        if (parent === dir) break;
        dir = parent;
    }
    return new Map();
}

function toIR(file, target = "host") {
    const src      = fs.readFileSync(file, "utf8");
    const bindings = loadBindings(file, target);
    const ast      = buildAstFromSource(src, { baseDir: path.dirname(path.resolve(file)), bindings });
    return genModule(ast, { target });
}

// Walk up from startDir to find the nearest directory containing hopper.json.
// Falls back to startDir itself if none is found.
function findProjectRoot(startDir) {
    let cursor = path.resolve(startDir);
    while (true) {
        if (fs.existsSync(path.join(cursor, "hopper.json"))) return cursor;
        const parent = path.dirname(cursor);
        if (parent === cursor) return path.resolve(startDir);
        cursor = parent;
    }
}

// Returns { projectRoot, buildDir, llDir, oDir } for the given entry file and profile.
function profileDirs(entryFile, profile) {
    const projectRoot = findProjectRoot(path.dirname(path.resolve(entryFile)));
    const buildDir    = path.join(projectRoot, "build", profile);
    const llDir       = path.join(buildDir, "ll");
    const oDir        = path.join(buildDir, "o");
    fs.mkdirSync(llDir, { recursive: true });
    fs.mkdirSync(oDir,  { recursive: true });
    return { projectRoot, buildDir, llDir, oDir };
}

// Clang flags per build profile.
function clangFlags(profile) {
    if (profile === "production") return "-O2 -c -fPIC -Wno-override-module";
    return "-g -O0 -c -fPIC -Wno-override-module"; // dev and test
}

// ── bare-metal board support ───────────────────────────────────────────────

// Known board configurations.  Adding a new board is just a new entry here.
const BOARD_CONFIGS = {
    "pi-zero": {
        // ── compile / link ────────────────────────────────────────────────
        llvmTarget:    "armv6-bare",
        clangTarget:   "arm-none-eabi",
        mcpu:          "arm1176jzf-s",
        floatAbi:      "soft",
        textBase:      0x8000,
        linkerEntry:   "_start",
        bootStub:      path.join(__dirname, "boards", "pi-zero", "boot.s"),

        // ── binary metadata (recorded in .meta.json after every build) ────
        meta: {
            arch:        "armv6",
            endian:      "little",
            bits:        32,
            loadAddress: "0x8000",
            entrySymbol: "_start",
        },

        // ── flash configuration ───────────────────────────────────────────
        flash: {
            method:          "sd-card",      // how to deliver the image
            outputFile:      "kernel.img",   // filename written to the SD card
            // firmware blobs that must already exist on the card
            requiredFirmware: ["bootcode.bin", "start.elf"],
            // lines the flash command ensures are present in config.txt
            configLines: [
                "init_uart_clock=3000000",
                "dtparam=act_led_trigger=none",
            ],
        },
    },
};

// Read the "board" field from hopper.json in the project root, if any.
function readBoard(projectRoot) {
    const mf = path.join(projectRoot, "hopper.json");
    if (!fs.existsSync(mf)) return null;
    try { return JSON.parse(fs.readFileSync(mf, "utf8")).board ?? null; }
    catch { return null; }
}

// Generate a minimal linker script for a known board.
// The entry symbol is always the boot stub's _start, which calls the Hopper entry.
function generateLinkerScript(cfg) {
    const base = `0x${cfg.textBase.toString(16)}`;
    return `ENTRY(${cfg.linkerEntry})
SECTIONS
{
    . = ${base};
    .text.boot : { KEEP(*(.text.boot)) }
    .text       : { *(.text*) }
    .rodata     : { *(.rodata*) }
    .data       : { *(.data*) }
    .bss        : {
        . = ALIGN(4);
        __bss_start = .;
        *(.bss*)
        *(COMMON)
        . = ALIGN(4);
        __bss_end = .;
    }
    /DISCARD/ : {
        *(.ARM.exidx*)
        *(.ARM.extab*)
        *(.note*)
    }
}
`;
}

// Compile one .hop file for a bare-metal target.
function dedupeDeclarations(ir) {
    const seen = new Set();
    return ir.split("\n").filter(line => {
        if (!line.startsWith("declare ")) return true;
        if (seen.has(line)) return false;
        seen.add(line);
        return true;
    }).join("\n");
}

function toObjectBare(file, llDir, oDir, cfg) {
    const src      = fs.readFileSync(file, "utf8");
    const bindings = loadBindings(file, cfg.llvmTarget);
    const ast      = buildAstFromSource(src, { baseDir: path.dirname(path.resolve(file)), bindings });
    const ir       = dedupeDeclarations(genModule(ast, { target: cfg.llvmTarget }));
    const llFile  = path.join(llDir, `${baseName(file)}.ll`);
    const objFile = path.join(oDir,  `${baseName(file)}.o`);
    fs.writeFileSync(llFile, ir, "utf8");
    const flags = `-target ${cfg.clangTarget} -mcpu=${cfg.mcpu} -mfloat-abi=${cfg.floatAbi} -ffreestanding -nostdlib -O2 -c -Wno-override-module`;
    execSync(`clang ${flags} "${llFile}" -o "${objFile}"`, { stdio: "inherit" });
    return { objFile, entryName: ast.entry?.name ?? "main" };
}

// Link bare-metal objects into an ELF then strip to a raw kernel.img.
// Writes a .meta.json file alongside the image for use by `hopper flash`.
function linkBare(bootObj, results, ldScript, outELF, outImg, binaryName, boardName, boardCfg) {
    const objs = [`"${bootObj}"`, ...results.map(r => `"${r.objFile}"`)].join(" ");
    execSync(`ld.lld -T "${ldScript}" ${objs} -o "${outELF}"`, { stdio: "inherit" });
    execSync(`llvm-objcopy -O binary "${outELF}" "${outImg}"`, { stdio: "inherit" });

    // Build metadata — consumed by `hopper flash`
    const metaPath = path.join(path.dirname(outImg), `${binaryName}.meta.json`);
    const meta = {
        name:       binaryName,
        board:      boardName,
        outputFile: boardCfg.flash.outputFile,
        ...boardCfg.meta,
        size:       fs.statSync(outImg).size,
        builtAt:    new Date().toISOString(),
    };
    fs.writeFileSync(metaPath, JSON.stringify(meta, null, 2) + "\n");
    return outImg;
}

// ── hosted build helpers ───────────────────────────────────────────────────

// Binary name: from hopper.json "name" field, or entry file basename.
function projectBinaryName(entryFile, projectRoot) {
    const mf = path.join(projectRoot, "hopper.json");
    if (fs.existsSync(mf)) {
        try {
            const m = JSON.parse(fs.readFileSync(mf, "utf8"));
            if (m.name) return m.name;
        } catch {}
    }
    return baseName(entryFile);
}

function toObject(file, llDir, oDir, flags) {
    const src      = fs.readFileSync(file, "utf8");
    const bindings = loadBindings(file, "host");
    const ast      = buildAstFromSource(src, { baseDir: path.dirname(path.resolve(file)), bindings });
    const ir       = dedupeDeclarations(genModule(ast));
    const llFile  = path.join(llDir, `${baseName(file)}.ll`);
    const objFile = path.join(oDir,  `${baseName(file)}.o`);
    fs.writeFileSync(llFile, ir, "utf8");
    execSync(`clang ${flags} "${llFile}" -o "${objFile}"`, { stdio: "inherit" });
    return { objFile, entryName: ast.entry?.name ?? "main" };
}

function link(results, outFile) {
    const objs = results.map(r => `"${r.objFile}"`).join(" ");
    execSync(`clang ${objs} -lpthread -o "${outFile}"`, { stdio: "inherit" });
    return outFile;
}

function compile(files, outFile, llDir, oDir, flags) {
    const results = files.map(f => toObject(f, llDir, oDir, flags));
    link(results, outFile);
    return outFile;
}

function findHopFiles(dir) {
    return fs.readdirSync(dir)
        .filter(f => f.endsWith(".hop"))
        .map(f => path.join(dir, f));
}

// ── flash helpers ──────────────────────────────────────────────────────────

// Read the full manifest from a given project root directory.
function readManifestAt(projectRoot) {
    const mf = path.join(projectRoot, "hopper.json");
    if (!fs.existsSync(mf)) return {};
    try { return JSON.parse(fs.readFileSync(mf, "utf8")); } catch { return {}; }
}

// Auto-detect a mounted SD card by looking for a known firmware file.
// On Linux reads /proc/mounts for vfat filesystems.
// On macOS scans /Volumes/.
function detectSdCard(flashCfg) {
    const marker = flashCfg.requiredFirmware[0];  // e.g. "bootcode.bin"

    if (process.platform === "linux") {
        try {
            const mounts = fs.readFileSync("/proc/mounts", "utf8");
            for (const line of mounts.split("\n")) {
                const parts = line.split(" ");
                if (parts[2] === "vfat" || parts[2] === "msdosfs") {
                    const mp = parts[1].replace(/\\040/g, " ");
                    if (fs.existsSync(path.join(mp, marker))) return mp;
                }
            }
        } catch { /* /proc not available */ }

        // Fallback: walk common user-mount locations
        for (const base of ["/media", "/mnt", "/run/media"]) {
            if (!fs.existsSync(base)) continue;
            try {
                for (const user of fs.readdirSync(base)) {
                    const userDir = path.join(base, user);
                    for (const vol of fs.readdirSync(userDir)) {
                        const mp = path.join(userDir, vol);
                        if (fs.existsSync(path.join(mp, marker))) return mp;
                    }
                }
            } catch { /* skip unreadable dirs */ }
        }
    }

    if (process.platform === "darwin") {
        try {
            for (const vol of fs.readdirSync("/Volumes")) {
                const mp = path.join("/Volumes", vol);
                if (fs.existsSync(path.join(mp, marker))) return mp;
            }
        } catch {}
    }

    return null;
}

// Ensure every line in `required` appears in the config.txt at `cfgPath`.
// Creates the file if it doesn't exist; otherwise appends only the missing lines.
function ensureConfigLines(cfgPath, required) {
    let existing = fs.existsSync(cfgPath) ? fs.readFileSync(cfgPath, "utf8") : "";
    const missing = required.filter(l => !existing.split("\n").some(e => e.trim() === l.trim()));
    if (missing.length === 0) return 0;
    if (existing.length > 0 && !existing.endsWith("\n")) existing += "\n";
    fs.writeFileSync(cfgPath, existing + missing.join("\n") + "\n");
    return missing.length;
}

// ── subcommands ────────────────────────────────────────────────────────────

function cmdBuild(args) {
    if (args[0] === "module") { cmdBuildModule(args.slice(1)); return; }

    // Parse build profile (default: dev)
    let profile = "dev";
    if (args.includes("--production")) profile = "production";
    else if (args.includes("--test"))  profile = "test";
    args = args.filter(a => a !== "--dev" && a !== "--production" && a !== "--test");

    const outputIdx = args.indexOf("-o");
    let output = null;
    if (outputIdx !== -1) {
        output = args[outputIdx + 1];
        args.splice(outputIdx, 2);
    }

    const files = args.length ? args : ["main.hop"];
    const missing = files.filter(f => !fs.existsSync(f));
    if (missing.length) {
        console.error(`hopper: file not found: ${missing.join(", ")}`);
        process.exit(1);
    }

    const { projectRoot, buildDir, llDir, oDir } = profileDirs(files[0], profile);
    const boardName = readBoard(projectRoot);
    const boardCfg  = boardName ? BOARD_CONFIGS[boardName] : null;

    if (boardCfg) {
        // ── bare-metal build ───────────────────────────────────────────────
        if (!boardCfg) {
            console.error(`hopper: unknown board '${boardName}'. Known boards: ${Object.keys(BOARD_CONFIGS).join(", ")}`);
            process.exit(1);
        }

        // Compile all .hop files for the target
        const results = files.map(f => toObjectBare(f, llDir, oDir, boardCfg));

        // Compile the board boot stub
        const bootObj = path.join(oDir, "boot.o");
        const asmFlags = `-target ${boardCfg.clangTarget} -mcpu=${boardCfg.mcpu} -mfloat-abi=${boardCfg.floatAbi} -ffreestanding -nostdlib -c`;
        execSync(`clang ${asmFlags} "${boardCfg.bootStub}" -o "${bootObj}"`, { stdio: "inherit" });

        // Write auto-generated linker script
        const ldScript = path.join(buildDir, "link.ld");
        fs.writeFileSync(ldScript, generateLinkerScript(boardCfg));

        // Link and convert to raw kernel.img
        const binaryName = output ? path.basename(output, ".img") : projectBinaryName(files[0], projectRoot);
        const outELF = path.join(buildDir, `${binaryName}.elf`);
        const outImg = output || path.join(buildDir, "kernel.img");
        linkBare(bootObj, results, ldScript, outELF, outImg, binaryName, boardName, boardCfg);
        console.log(`built [bare-metal/${boardName}]: ${outImg}`);
    } else {
        // ── hosted build ──────────────────────────────────────────────────
        const flags   = clangFlags(profile);
        const results = files.map(f => toObject(f, llDir, oDir, flags));
        const outFile = output || path.join(buildDir, projectBinaryName(files[0], projectRoot));
        link(results, outFile);
        console.log(`built [${profile}]: ${outFile}`);
    }
}

function cmdBuildModule(args) {
    const name = args[0];
    if (!name) {
        console.error("hopper: build module requires a name");
        process.exit(1);
    }

    const moduleDir = path.join(MODULES_DIR, name);
    const testsDir  = path.join(moduleDir, "tests");
    const existed   = fs.existsSync(moduleDir);

    fs.mkdirSync(testsDir, { recursive: true });

    if (existed) {
        console.log(`module: ${name}  (already exists)`);
        console.log(`  ensured: modules/${name}/tests/`);
    } else {
        console.log(`module: ${name}`);
        console.log(`  created: modules/${name}/`);
        console.log(`  created: modules/${name}/tests/`);
    }
}

// hopper run — execute binaries and tests, NOT a compiler
function cmdRun(args) {
    // hopper run test [module]
    if (args[0] === "test") { cmdTest(args.slice(1)); return; }

    // hopper run <binary>  — execute a specific binary
    if (args[0]) {
        const bin = path.resolve(args[0]);
        if (!fs.existsSync(bin)) {
            console.error(`hopper: binary not found: ${args[0]}`);
            process.exit(1);
        }
        execSync(bin, { stdio: "inherit" });
        return;
    }

    // hopper run — find and execute the dev build from the project's build/dev/
    const projectRoot = findProjectRoot(process.cwd());
    const mf = path.join(projectRoot, "hopper.json");
    let name = "main";
    if (fs.existsSync(mf)) {
        try { name = JSON.parse(fs.readFileSync(mf, "utf8")).name || name; } catch {}
    }
    const bin = path.join(projectRoot, "build", "dev", name);
    if (!fs.existsSync(bin)) {
        console.error(`hopper: no binary at ${bin} — run 'hopper build' first`);
        process.exit(1);
    }
    execSync(bin, { stdio: "inherit" });
}

function cmdDev(args) {
    const files = args.length ? args : ["main.hop"];
    const missing = files.filter(f => !fs.existsSync(f));
    if (missing.length) {
        console.error(`hopper: file not found: ${missing.join(", ")}`);
        process.exit(1);
    }

    const { projectRoot, buildDir, llDir, oDir } = profileDirs(files[0], "dev");
    const flags   = clangFlags("dev");
    const outFile = path.join(buildDir, projectBinaryName(files[0], projectRoot));
    const watchDirs = [...new Set(files.map(f => path.dirname(path.resolve(f))))];

    let running = null;
    let rebuilding = false;
    let dirty = false;

    function runProcess() {
        if (running) {
            running.kill();
            running = null;
        }
        try {
            running = spawn(outFile, [], { stdio: "inherit" });
            running.on("exit", (code) => {
                if (code !== null) process.stdout.write(`\n[hopper dev] exited (${code})\n`);
                running = null;
            });
        } catch (e) {
            console.error(`[hopper dev] failed to start: ${e.message}`);
        }
    }

    function rebuild() {
        if (rebuilding) { dirty = true; return; }
        rebuilding = true;
        dirty = false;
        console.log("\n[hopper dev] rebuilding...");
        try {
            compile(files, outFile, llDir, oDir, flags);
            console.log("[hopper dev] ok — running");
            runProcess();
        } catch (e) {
            console.error("[hopper dev] build failed");
        }
        rebuilding = false;
        if (dirty) setTimeout(rebuild, 50);
    }

    console.log(`[hopper dev] watching ${watchDirs.join(", ")} ...`);
    rebuild();

    let debounce = null;
    for (const dir of watchDirs) {
        fs.watch(dir, { recursive: false }, (event, filename) => {
            if (filename && filename.endsWith(".hop")) {
                clearTimeout(debounce);
                debounce = setTimeout(rebuild, 150);
            }
        });
    }
}

function readManifest() {
    const mf = "hopper.json";
    if (!fs.existsSync(mf)) return null;
    try { return JSON.parse(fs.readFileSync(mf, "utf8")); }
    catch (e) { console.error(`hopper: bad hopper.json — ${e.message}`); process.exit(1); }
}

function writeManifest(obj) {
    fs.writeFileSync("hopper.json", JSON.stringify(obj, null, 2) + "\n", "utf8");
}

async function cmdInit(args) {
    // Parse flags: --yes/-y skips prompts, --type=library|executable, --description=..., --license=...
    const yesFlag   = args.includes("--yes") || args.includes("-y");
    const typeFlag  = (args.find(a => a.startsWith("--type="))        || "").slice("--type=".length)        || null;
    const descFlag  = (args.find(a => a.startsWith("--description=")) || "").slice("--description=".length) || null;
    const licFlag   = (args.find(a => a.startsWith("--license="))     || "").slice("--license=".length)     || null;
    const versionFlag = (args.find(a => a.startsWith("--version="))   || "").slice("--version=".length)     || null;
    const nameArg   = args.find(a => !a.startsWith("-"));

    if (!nameArg) {
        console.error("hopper: init requires a project name  —  hopper init <name>");
        process.exit(1);
    }

    const rawName  = nameArg;
    const safeName = rawName.replace(/[^a-zA-Z0-9_-]/g, "_");
    const projectDir = path.resolve(process.cwd(), safeName);

    if (fs.existsSync(projectDir)) {
        console.error(`hopper: '${safeName}' already exists`);
        process.exit(1);
    }

    let name, version, description, license, typeChoice;

    if (yesFlag) {
        name        = safeName;
        version     = versionFlag  || "0.1.0";
        description = descFlag     || "";
        license     = licFlag      || "MIT";
        typeChoice  = typeFlag     || "executable";
    } else {
        const rl  = readline.createInterface({ input: process.stdin, output: process.stdout });
        const ask = (q, def) => new Promise(resolve =>
            rl.question(`${q}: ${def ? `(${def}) ` : ""}`, ans => resolve(ans.trim() || def || ""))
        );

        console.log("\nThis utility will walk you through creating a hopper.json file.\n");

        name        = await ask("name",        safeName);
        version     = await ask("version",     versionFlag  || "0.1.0");
        description = await ask("description", descFlag     || "");
        license     = await ask("license",     licFlag      || "MIT");
        typeChoice  = await ask("type (executable/library)", typeFlag || "executable");

        const isLibPreview = typeChoice.startsWith("l");
        const previewManifest = isLibPreview ? {
            name, version, description, license,
            type: "library",
            main: `src/${name}.hop`,
        } : {
            name, version, description, license,
            type: "executable",
            entry: "src/main.hop",
            targets: { host: {} },
        };
        console.log(`\n${JSON.stringify(previewManifest, null, 2)}\n`);

        const confirm = await ask("Is this ok?", "yes");
        rl.close();
        if (confirm !== "yes" && confirm !== "y") {
            console.log("aborted.");
            process.exit(0);
        }
    }

    const isLib = typeChoice.startsWith("l");

    const manifest = isLib ? {
        name, version, description, license,
        type: "library",
        main: `src/${name}.hop`,
    } : {
        name, version, description, license,
        type: "executable",
        entry: "src/main.hop",
        targets: {
            host: {},
        },
    };

    if (yesFlag) {
        console.log(`\ncreating ${safeName} (${manifest.type})...`);
    }

    fs.mkdirSync(path.join(projectDir, "src"),        { recursive: true });
    fs.mkdirSync(path.join(projectDir, "modules"),     { recursive: true });
    fs.mkdirSync(path.join(projectDir, "tests"),       { recursive: true });
    if (!isLib) {
        fs.mkdirSync(path.join(projectDir, "interfaces"), { recursive: true });
    }
    fs.writeFileSync(path.join(projectDir, "modules", ".gitkeep"), "", "utf8");
    fs.writeFileSync(path.join(projectDir, "tests",   ".gitkeep"), "", "utf8");

    const entryFile = isLib
        ? path.join(projectDir, "src", `${name}.hop`)
        : path.join(projectDir, "src", "main.hop");
    fs.writeFileSync(entryFile, "", "utf8");

    fs.writeFileSync(path.join(projectDir, "hopper.json"),
        JSON.stringify(manifest, null, 2) + "\n", "utf8");

    fs.writeFileSync(path.join(projectDir, ".gitignore"), "build/\n", "utf8");

    console.log(`\ncreated ${safeName}/`);
    console.log(`  ${safeName}/hopper.json`);
    console.log(`  ${safeName}/src/`);
    if (!isLib) console.log(`  ${safeName}/interfaces/`);
    console.log(`  ${safeName}/modules/`);
    console.log(`  ${safeName}/tests/`);
}

// ── package helpers ────────────────────────────────────────────────────────

function fetchTarball(url, destDir) {
    return new Promise((resolve, reject) => {
        const tmp = path.join(destDir, `_pkg_${Date.now()}.tar.gz`);
        const file = fs.createWriteStream(tmp);

        function get(url) {
            https.get(url, { headers: { "User-Agent": "hopper-cli" } }, res => {
                if (res.statusCode === 301 || res.statusCode === 302) {
                    get(res.headers.location);
                    return;
                }
                if (res.statusCode !== 200) {
                    reject(new Error(`HTTP ${res.statusCode} fetching ${url}`));
                    return;
                }
                res.pipe(file);
                file.on("finish", () => {
                    file.close();
                    fs.mkdirSync(destDir, { recursive: true });
                    try {
                        execSync(`tar -xz -f "${tmp}" -C "${destDir}" --strip-components=1`, { stdio: "pipe" });
                        fs.unlinkSync(tmp);
                        resolve();
                    } catch (e) { reject(e); }
                });
            }).on("error", reject);
        }
        get(url);
    });
}

async function cmdInstall(args) {
    const LOCAL_MODULES = path.join(process.cwd(), "modules");
    const STDLIB_DIR    = path.join(__dirname, "..", "..", "hopper", "modules");
    let names = args.filter(a => !a.startsWith("-"));

    // No args — reinstall everything from hopper.json
    if (names.length === 0) {
        const manifest = readManifest();
        if (!manifest) {
            console.error("hopper: no hopper.json and no package names given");
            process.exit(1);
        }
        const deps = manifest.dependencies || {};
        if (Object.keys(deps).length === 0) { console.log("hopper: nothing to install"); return; }
        names = Object.keys(deps);
    }

    fs.mkdirSync(LOCAL_MODULES, { recursive: true });

    for (const name of names) {
        const dest = path.join(LOCAL_MODULES, name);
        if (fs.existsSync(dest)) { console.log(`already installed: ${name}`); continue; }

        // Try stdlib first
        const stdlibSrc = path.join(STDLIB_DIR, name);
        if (fs.existsSync(stdlibSrc)) {
            copyDir(stdlibSrc, dest);
            console.log(`installed: ${name}  (stdlib)`);
            updateDep(name, "stdlib");
            continue;
        }

        // Fetch from registry (GitHub org)
        const tarUrl = `https://codeload.github.com/${REGISTRY_ORG}/${name}/tar.gz/refs/heads/main`;
        console.log(`installing: ${name}  from ${REGISTRY_URL}/${name}`);
        try {
            const tmp = path.join(LOCAL_MODULES, `_${name}_tmp`);
            await fetchTarball(tarUrl, tmp);
            // Package must have a modules/<name>/ folder — move it into place
            const inner = path.join(tmp, "modules", name);
            if (fs.existsSync(inner)) {
                fs.renameSync(inner, dest);
                fs.rmSync(tmp, { recursive: true, force: true });
            } else {
                // Repo root IS the module
                fs.renameSync(tmp, dest);
            }
            console.log(`installed: ${name}  ✓`);
            updateDep(name, `${REGISTRY_ORG}/${name}`);
        } catch (e) {
            console.error(`failed: ${name}  — ${e.message}`);
            process.exit(1);
        }
    }
}

function updateDep(name, source) {
    const manifest = readManifest() || { name: path.basename(process.cwd()), version: "0.1.0", entry: "main.hop", dependencies: {} };
    manifest.dependencies[name] = source;
    writeManifest(manifest);
}

function cmdUninstall(args) {
    if (!args[0]) { console.error("hopper: uninstall requires a package name"); process.exit(1); }
    const LOCAL_MODULES = path.join(process.cwd(), "modules");

    for (const name of args) {
        const dest = path.join(LOCAL_MODULES, name);
        if (!fs.existsSync(dest)) { console.log(`not installed: ${name}`); continue; }
        fs.rmSync(dest, { recursive: true, force: true });
        const manifest = readManifest();
        if (manifest && manifest.dependencies) {
            delete manifest.dependencies[name];
            writeManifest(manifest);
        }
        console.log(`uninstalled: ${name}`);
    }
}

function githubAPI(method, endpoint, body, token) {
    return new Promise((resolve, reject) => {
        const data = body ? JSON.stringify(body) : null;
        const opts = {
            hostname: "api.github.com",
            path: endpoint,
            method,
            headers: {
                "Authorization": `Bearer ${token}`,
                "User-Agent": "hopper-cli",
                "Accept": "application/vnd.github+json",
                "X-GitHub-Api-Version": "2022-11-28",
                ...(data ? { "Content-Type": "application/json", "Content-Length": Buffer.byteLength(data) } : {}),
            },
        };
        const req = https.request(opts, res => {
            let buf = "";
            res.on("data", chunk => buf += chunk);
            res.on("end", () => {
                let parsed = null;
                try { parsed = buf ? JSON.parse(buf) : null; } catch { parsed = null; }
                resolve({ status: res.statusCode, body: parsed });
            });
        });
        req.on("error", reject);
        if (data) req.write(data);
        req.end();
    });
}

function requireToken() {
    const token = process.env.HOPPER_TOKEN || process.env.GITHUB_TOKEN;
    if (!token) {
        console.error("hopper: publish/revoke requires HOPPER_TOKEN or GITHUB_TOKEN env var");
        process.exit(1);
    }
    return token;
}

async function cmdPublish(args) {
    const manifest = readManifest();
    if (!manifest) { console.error("hopper: no hopper.json found"); process.exit(1); }

    const name    = args[0] || manifest.name;
    const version = manifest.version || "0.1.0";
    const repoUrl = `${REGISTRY_URL}/${name}`;
    const token   = requireToken();

    try { execSync("git rev-parse --git-dir", { stdio: "pipe" }); }
    catch { console.error("hopper: publish requires a git repository"); process.exit(1); }

    console.log(`publishing: ${name}@${version}  →  ${repoUrl}`);

    const res = await githubAPI("POST", `/orgs/${REGISTRY_ORG}/repos`, { name, private: false }, token);
    if (res.status !== 201 && res.status !== 422) {
        console.error(`hopper: failed to create registry repo — ${res.body?.message || res.status}`);
        process.exit(1);
    }

    try {
        execSync(`git remote add registry ${repoUrl}.git 2>/dev/null; true`, { stdio: "pipe", shell: true });
        execSync(`git push registry main`, { stdio: "inherit" });
    } catch (e) {
        console.error(`hopper: publish failed — ${e.message}`);
        process.exit(1);
    }

    console.log(`published: ${name}@${version}  ✓`);
    console.log(`  ${repoUrl}`);
    console.log(`  hopper install ${name}`);
}

async function cmdRevoke(args) {
    const manifest = readManifest();
    const name     = args[0] || (manifest && manifest.name);
    if (!name) { console.error("hopper: revoke requires a package name"); process.exit(1); }

    const token = requireToken();

    const rl  = readline.createInterface({ input: process.stdin, output: process.stdout });
    const ask = (q) => new Promise(resolve => rl.question(q, ans => resolve(ans.trim())));

    console.log(`\n  This will delete ${REGISTRY_ORG}/${name} from the registry permanently.`);
    console.log(`  Anyone who has not installed it yet will no longer be able to.\n`);
    const confirm = await ask(`  type the package name to confirm: `);
    rl.close();

    if (confirm !== name) { console.log("aborted."); process.exit(0); }

    const res = await githubAPI("DELETE", `/repos/${REGISTRY_ORG}/${name}`, null, token);
    if (res.status !== 204) {
        console.error(`hopper: revoke failed — ${res.body?.message || res.status}`);
        process.exit(1);
    }
    console.log(`revoked: ${name}  — registry entry deleted`);
}

function copyDir(src, dest) {
    fs.mkdirSync(dest, { recursive: true });
    for (const entry of fs.readdirSync(src, { withFileTypes: true })) {
        const s = path.join(src, entry.name);
        const d = path.join(dest, entry.name);
        if (entry.isDirectory()) copyDir(s, d);
        else fs.copyFileSync(s, d);
    }
}

