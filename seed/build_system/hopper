// ── flash ──────────────────────────────────────────────────────────────────

function cmdFlash(args) {
    // ── parse flags ───────────────────────────────────────────────────────
    let mountArg = null;
    let dryRun   = false;
    let profile  = "dev";
    for (let i = 0; i < args.length; i++) {
        if (args[i] === "--mount" || args[i] === "-m")  { mountArg = args[++i]; continue; }
        if (args[i].startsWith("--mount="))             { mountArg = args[i].slice(8); continue; }
        if (args[i] === "--dry-run")                    { dryRun   = true; continue; }
        if (args[i] === "--production")                 { profile  = "production"; continue; }
    }

    // ── load project ──────────────────────────────────────────────────────
    const projectRoot = findProjectRoot(process.cwd());
    const manifest    = readManifestAt(projectRoot);
    const boardName   = manifest.board;

    if (!boardName) {
        console.error("hopper: 'board' is not set in hopper.json — flash only works for bare-metal targets");
        process.exit(1);
    }

    const boardCfg = BOARD_CONFIGS[boardName];
    if (!boardCfg?.flash) {
        console.error(`hopper: board '${boardName}' does not have a flash configuration`);
        process.exit(1);
    }

    const flashCfg = boardCfg.flash;

    // ── locate built binary ───────────────────────────────────────────────
    const buildDir  = path.join(projectRoot, "build", profile);
    const imgPath   = path.join(buildDir, flashCfg.outputFile);
    const name      = manifest.name || "project";
    const metaPath  = path.join(buildDir, `${name}.meta.json`);

    if (!fs.existsSync(imgPath)) {
        console.error([
            `hopper: ${flashCfg.outputFile} not found at ${buildDir}`,
            `  Run 'hopper build' first.`,
        ].join("\n"));
        process.exit(1);
    }

    // ── read build metadata ───────────────────────────────────────────────
    let meta = null;
    if (fs.existsSync(metaPath)) {
        try { meta = JSON.parse(fs.readFileSync(metaPath, "utf8")); } catch {}
    }

    // ── find the SD card ──────────────────────────────────────────────────
    const mountOverride = mountArg || manifest.flash?.mount || null;
    let mountPoint = mountOverride;

    if (!mountPoint) {
        mountPoint = detectSdCard(flashCfg);
        if (!mountPoint) {
            console.error([
                `hopper: could not auto-detect an SD card with ${flashCfg.requiredFirmware[0]}.`,
                ``,
                `  Make sure the card is mounted, then try again.`,
                `  Or specify the path explicitly:`,
                `    hopper flash --mount /path/to/sdcard`,
                ``,
                `  The SD card needs the Pi Zero firmware blobs in its root:`,
                `    bootcode.bin  start.elf`,
                `  Download from: https://github.com/raspberrypi/firmware/tree/master/boot`,
            ].join("\n"));
            process.exit(1);
        }
    }

    // ── verify required firmware blobs ────────────────────────────────────
    const missing = flashCfg.requiredFirmware.filter(f => !fs.existsSync(path.join(mountPoint, f)));
    if (missing.length) {
        console.error([
            `hopper: missing firmware on SD card at ${mountPoint}:`,
            ...missing.map(f => `  ✗  ${f}`),
            ``,
            `  Download from: https://github.com/raspberrypi/firmware/tree/master/boot`,
            `  Copy the missing files to the SD card root and try again.`,
        ].join("\n"));
        process.exit(1);
    }

    // ── print summary ─────────────────────────────────────────────────────
    const imgSize = fs.statSync(imgPath).size;
    const arch    = meta?.arch    ?? boardCfg.meta?.arch    ?? "unknown";
    const endian  = meta?.endian  ?? boardCfg.meta?.endian  ?? "unknown";
    const bits    = meta?.bits    ?? boardCfg.meta?.bits    ?? "?";
    const loadAt  = meta?.loadAddress ?? boardCfg.meta?.loadAddress ?? "?";

    console.log(`\nhopper: flash  ${name}  →  ${mountPoint}`);
    console.log(`  board     ${boardName}  (${arch} ${endian}-endian ${bits}-bit, load ${loadAt})`);
    if (meta?.builtAt) {
        const when = new Date(meta.builtAt).toLocaleString();
        console.log(`  built     ${when}`);
    }
    console.log(`  image     ${flashCfg.outputFile}  (${(imgSize / 1024).toFixed(1)} KB)`);
    for (const f of flashCfg.requiredFirmware) {
        console.log(`  found     ${f} ✓`);
    }

    if (dryRun) {
        console.log(`\n  [dry run — nothing written]\n`);
        return;
    }

    // ── copy kernel image ─────────────────────────────────────────────────
    const destImg = path.join(mountPoint, flashCfg.outputFile);
    fs.copyFileSync(imgPath, destImg);
    console.log(`  wrote     ${flashCfg.outputFile}`);

    // ── ensure config.txt has required lines ──────────────────────────────
    if (flashCfg.configLines?.length) {
        const cfgPath = path.join(mountPoint, "config.txt");
        const added   = ensureConfigLines(cfgPath, flashCfg.configLines);
        if (added > 0) {
            console.log(`  wrote     config.txt  (+${added} line${added > 1 ? "s" : ""})`);
        } else {
            console.log(`  config.txt already up to date ✓`);
        }
    }

    // ── sync ─────────────────────────────────────────────────────────────
    try { execSync("sync", { stdio: "ignore" }); } catch {}
    console.log(`\nhopper: done — remove SD card safely, insert in Pi Zero, power on\n`);
}

