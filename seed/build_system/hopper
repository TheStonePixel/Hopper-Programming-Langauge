        const src = fs.readFileSync(file, "utf8");
        const ast = buildAstFromSource(src, { baseDir: path.dirname(path.resolve(file)), noImports: true });
        const formatted = formatSource(ast, src);
        if (inPlace) {
            fs.writeFileSync(file, formatted, "utf8");
            console.log(`formatted: ${file}`);
        } else {
            process.stdout.write(formatted);
        }
    }
}

