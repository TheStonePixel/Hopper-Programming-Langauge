extern function putchar(int c) int

function main() int {
  // Test break: print 0-4 then break
  for (int i = 0; i < 10; i = i + 1) {
    if (i == 5) {
      break
    }
    putchar('0' + i)
  }
  putchar('\n')

  // Test continue: print 0-9 but skip 5
  for (int j = 0; j < 10; j = j + 1) {
    if (j == 5) {
      continue
    }
    putchar('0' + j)
  }
  putchar('\n')

  return 0
}
