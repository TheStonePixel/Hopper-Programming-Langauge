// EXPECT: Hello 🌍
// EXPECT: Hopper is 🔥
// EXPECT: Let's go 🚀
// EXPECT: 💻 + 🤖 = ❤
import utf8 from string
import io from linux

entry main {
    String s = String(64)

    // "Hello 🌍"  — U+1F30D = 127757 (Earth Globe, 4-byte UTF-8)
    s.append(72)       // H
    s.append(101)      // e
    s.append(108)      // l
    s.append(108)      // l
    s.append(111)      // o
    s.append(32)       // space
    s.append(127757)   // 🌍
    s.append(10)
    write(1, s.pointer(), s.length())
    s.clear()

    // "Hopper is 🔥"  — U+1F525 = 128293 (Fire, 4-byte UTF-8)
    s.append(72)       // H
    s.append(111)      // o
    s.append(112)      // p
    s.append(112)      // p
    s.append(101)      // e
    s.append(114)      // r
    s.append(32)       // space
    s.append(105)      // i
    s.append(115)      // s
    s.append(32)       // space
    s.append(128293)   // 🔥
    s.append(10)
    write(1, s.pointer(), s.length())
    s.clear()

    // "Let's go 🚀"  — U+1F680 = 128640 (Rocket, 4-byte UTF-8)
    s.append(76)       // L
    s.append(101)      // e
    s.append(116)      // t
    s.append(39)       // '
    s.append(115)      // s
    s.append(32)       // space
    s.append(103)      // g
    s.append(111)      // o
    s.append(32)       // space
    s.append(128640)   // 🚀
    s.append(10)
    write(1, s.pointer(), s.length())
    s.clear()

    // "💻 + 🤖 = ❤"
    s.append(128187)   // 💻  U+1F4BB Laptop
    s.append(32)       // space
    s.append(43)       // +
    s.append(32)       // space
    s.append(129302)   // 🤖  U+1F916 Robot
    s.append(32)       // space
    s.append(61)       // =
    s.append(32)       // space
    s.append(10084)    // ❤   U+2764 Heart (3-byte UTF-8)
    s.append(10)
    write(1, s.pointer(), s.length())
}
