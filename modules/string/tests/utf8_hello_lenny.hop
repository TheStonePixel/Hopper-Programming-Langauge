// Demonstrates in-place mutation with set() and concatenation with appendString().
// EXPECT: Hello, World
// EXPECT: Hello, Lenny
// EXPECT: Hello, World Hello, Lenny
import ascii from string
import io from linux

entry main {
    String s = String(16)
    s.append(72)    // H
    s.append(101)   // e
    s.append(108)   // l
    s.append(108)   // l
    s.append(111)   // o
    s.append(44)    // ,
    s.append(32)    // space
    s.append(87)    // W
    s.append(111)   // o
    s.append(114)   // r
    s.append(108)   // l
    s.append(100)   // d
    s.append(10)    // newline
    write(1, s.pointer(), s.length())

    // Mutate "World" → "Lenny" at indices 7–11
    s.set(7, 76)    // L
    s.set(8, 101)   // e
    s.set(9, 110)   // n
    s.set(10, 110)  // n
    s.set(11, 121)  // y
    write(1, s.pointer(), s.length())

    // Build a third string by appending both
    String world = String(16)
    world.append(72)    // H
    world.append(101)   // e
    world.append(108)   // l
    world.append(108)   // l
    world.append(111)   // o
    world.append(44)    // ,
    world.append(32)    // space
    world.append(87)    // W
    world.append(111)   // o
    world.append(114)   // r
    world.append(108)   // l
    world.append(100)   // d
    world.append(32)    // space

    String combined = String(32)
    combined.appendString(world)
    combined.appendString(s)
    write(1, combined.pointer(), combined.length())
}
