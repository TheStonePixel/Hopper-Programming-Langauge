// EXPECT: hello
// EXPECT: 42
// EXPECT: ff
// EXPECT: 0
import String from ascii
import io from linux

entry main {
    String s = String(8)
    s.append(104)
    s.append(101)
    s.append(108)
    s.append(108)
    s.append(111)
    s.append(10)
    write(1, s.pointer(), s.length())

    String n = String(16)
    n.appendNumber(42)
    n.append(10)
    write(1, n.pointer(), n.length())

    String h = String(16)
    h.appendHex(255)
    h.append(10)
    write(1, h.pointer(), h.length())

    String z = String(4)
    z.appendNumber(0)
    z.append(10)
    write(1, z.pointer(), z.length())
}
