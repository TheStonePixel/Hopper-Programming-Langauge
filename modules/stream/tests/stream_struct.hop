import assert from core
import io     from core
import stream from stream

// Structs are compile-time declarations with fixed, known size.
// T::size is a constant, address arithmetic is exact, and Stream<Point>
// works the same way Stream<byte> does — no runtime type info required.
//
// We allocate a raw block and write Point values into it using
// ptr::value = val — the same mechanism Array<T>.set() uses internally.
// This avoids pulling in Array<T>, which can't compile indexOf for structs.

// TEST: peek does not advance
// EXPECT: peek struct ok

// TEST: advance moves cursor through struct array
// EXPECT: advance struct ok

// TEST: remaining counts elements not bytes
// EXPECT: remaining struct ok

// TEST: retreat steps back one struct
// EXPECT: retreat struct ok

// TEST: peekAt looks ahead without advancing
// EXPECT: peekAt struct ok

struct Point {
    int x
    int y
}

entry main {
    // Allocate a contiguous block for 3 Points and fill them in.
    address block = allocate 3 * Point::size

    Point p0
    p0.x = 10
    p0.y = 20
    address w0 = block + (0 * Point::size)
    w0::value = p0

    Point p1
    p1.x = 30
    p1.y = 40
    address w1 = block + (1 * Point::size)
    w1::value = p1

    Point p2
    p2.x = 50
    p2.y = 60
    address w2 = block + (2 * Point::size)
    w2::value = p2

    // — peek does not advance ——————————————————————————————
    Stream<Point> st = Stream(block, 3)
    Point a = st.peek()
    Point b = st.peek()
    soft(a.x == 10, "peek: expected x=10\n")
    soft(a.y == 20, "peek: expected y=20\n")
    soft(b.x == 10, "peek: should not advance\n")
    soft(st.pos == 0, "peek: pos should stay 0\n")
    println("peek struct ok")

    // — advance moves cursor ———————————————————————————————
    Stream<Point> st2 = Stream(block, 3)
    Point c = st2.advance()
    Point d = st2.advance()
    soft(c.x == 10, "advance: first x should be 10\n")
    soft(c.y == 20, "advance: first y should be 20\n")
    soft(d.x == 30, "advance: second x should be 30\n")
    soft(d.y == 40, "advance: second y should be 40\n")
    soft(st2.pos == 2, "advance: pos should be 2\n")
    println("advance struct ok")

    // — remaining counts elements not bytes ———————————————
    Stream<Point> st3 = Stream(block, 3)
    soft(st3.remaining() == 3, "remaining: expected 3\n")
    st3.advance()
    soft(st3.remaining() == 2, "remaining: expected 2 after 1 advance\n")
    st3.advance()
    st3.advance()
    soft(st3.remaining() == 0, "remaining: expected 0 at end\n")
    println("remaining struct ok")

    // — retreat steps back one struct —————————————————————
    Stream<Point> st4 = Stream(block, 3)
    st4.advance()
    st4.advance()
    st4.retreat()
    soft(st4.pos == 1, "retreat: pos should be 1\n")
    Point e = st4.peek()
    soft(e.x == 30, "retreat: should see second point\n")
    soft(e.y == 40, "retreat: y should match\n")
    println("retreat struct ok")

    // — peekAt looks ahead without advancing ——————————————
    Stream<Point> st5 = Stream(block, 3)
    Point f = st5.peekAt(0)
    Point g = st5.peekAt(1)
    Point h = st5.peekAt(2)
    soft(f.x == 10, "peekAt(0): expected x=10\n")
    soft(g.x == 30, "peekAt(1): expected x=30\n")
    soft(h.x == 50, "peekAt(2): expected x=50\n")
    soft(h.y == 60, "peekAt(2): expected y=60\n")
    soft(st5.pos == 0, "peekAt: pos should not change\n")
    println("peekAt struct ok")

    deallocate block
}
