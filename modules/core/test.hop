// test.hop — lightweight test suite for Hopper
//
// TestSuite tracks pass/fail counts and prints PASS/FAIL per assertion.
// Call done() at the end; it prints a summary and exits 1 on any failure.
//
// Usage:
//   import test from core
//
//   TestSuite t = TestSuite("my tests")
//   t.check(1 == 1, "one equals one")
//   t.checkEq(2 + 2, 4, "addition")
//   t.checkStrEq(s, "hello", "greeting")
//   t.checkNull(ptr, "ptr is null")
//   t.done()

import io  from core
import sys from target

class TestSuite {
    int     pass
    int     fail
    address suiteName

    constructor(address name) {
        self.pass      = 0
        self.fail      = 0
        self.suiteName = name
    }

    function check(bool cond, address label) {
        if (cond) {
            print("PASS  ")
            println(label)
            self.pass = self.pass + 1
        } else {
            print("FAIL  ")
            println(label)
            self.fail = self.fail + 1
        }
    }

    function checkEq(int actual, int expected, address label) {
        bool ok = actual == expected
        if (ok) {
            print("PASS  ")
            println(label)
            self.pass = self.pass + 1
        } else {
            print("FAIL  ")
            print(label)
            print("  (got ")
            printInt(actual)
            print(", want ")
            printInt(expected)
            println(")")
            self.fail = self.fail + 1
        }
    }

    function checkStrEq(address actual, address expected, address label) {
        bool ok = strEq(actual, expected)
        if (ok) {
            print("PASS  ")
            println(label)
            self.pass = self.pass + 1
        } else {
            print("FAIL  ")
            print(label)
            print("  (got \"")
            print(actual)
            print("\", want \"")
            print(expected)
            println("\")")
            self.fail = self.fail + 1
        }
    }

    function checkNull(address ptr, address label) {
        bool ok = ptr == null
        if (ok) {
            print("PASS  ")
            println(label)
            self.pass = self.pass + 1
        } else {
            print("FAIL  ")
            print(label)
            println("  (expected null, got non-null)")
            self.fail = self.fail + 1
        }
    }

    function checkNotNull(address ptr, address label) {
        bool ok = ptr != null
        if (ok) {
            print("PASS  ")
            println(label)
            self.pass = self.pass + 1
        } else {
            print("FAIL  ")
            print(label)
            println("  (expected non-null, got null)")
            self.fail = self.fail + 1
        }
    }

    // Print summary line and exit 1 if any test failed. Returns true on full pass.
    function done() bool {
        print(self.suiteName)
        print(": ")
        printInt(self.pass)
        print(" passed, ")
        printInt(self.fail)
        println(" failed")
        if (self.fail > 0) {
            exit(1)
        }
        return self.fail == 0
    }
}

// strEq — local helper so test.hop has no circular import on assert.hop.
// Compare two null-terminated strings.
function strEq(address a, address b) bool {
    int i = 0
    while (true) {
        address pa = a + i
        address pb = b + i
        byte ba = pa::value
        byte bb = pb::value
        int ai = cast ba
        int bi = cast bb
        if (ai != bi) { return false }
        if (ai == 0)  { return true }
        i = i + 1
    }
    return false
}
