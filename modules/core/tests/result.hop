// EXPECT: ok isOk = 1
// EXPECT: ok unwrap = 42
// EXPECT: ok unwrapOr = 42
// EXPECT: err isOk = 0
// EXPECT: err isErr = 1
// EXPECT: err errorCode = 404
// EXPECT: err unwrapOr = 0

import result from core
extern function printf(string fmt, ...) int

entry main {
    Result<int> ok = Result(1, 42, 0)
    printf("ok isOk = %lld\n",    ok.isOk())
    printf("ok unwrap = %lld\n",  ok.unwrap())
    printf("ok unwrapOr = %lld\n", ok.unwrapOr(0))

    Result<int> err = Result(0, 0, 404)
    printf("err isOk = %lld\n",     err.isOk())
    printf("err isErr = %lld\n",    err.isErr())
    printf("err errorCode = %lld\n", err.errorCode())
    printf("err unwrapOr = %lld\n",  err.unwrapOr(0))
}
