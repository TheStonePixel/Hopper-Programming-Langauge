// EXPECT: upper: A Z A 1
// EXPECT: lower: a z a 1
// EXPECT: digitVal: 0 9 -1
// EXPECT: hexVal: 0 9 10 15 10 15 -1

import io from io
import char from char

entry main(int argc, address argv) {
    byte a   = cast 'a'
    byte zl  = cast 'z'
    byte A   = cast 'A'
    byte one = cast '1'

    print("upper: ")
    print(toUpper(a))
    print(" ")
    print(toUpper(zl))
    print(" ")
    print(toUpper(A))
    print(" ")
    print(toUpper(one))
    newline()

    print("lower: ")
    print(toLower(a))
    print(" ")
    print(toLower(zl))
    print(" ")
    print(toLower(A))
    print(" ")
    print(toLower(one))
    newline()

    byte zero = cast '0'
    byte nine = cast '9'
    byte bang = cast '!'
    print("digitVal: ")
    print(digitVal(zero))
    print(" ")
    print(digitVal(nine))
    print(" ")
    print(digitVal(bang))
    newline()

    byte hexA  = cast 'A'
    byte hexF  = cast 'F'
    byte hexaf = cast 'a'
    byte hexff = cast 'f'
    byte hexX  = cast 'X'
    print("hexVal: ")
    print(hexVal(zero))
    print(" ")
    print(hexVal(nine))
    print(" ")
    print(hexVal(hexA))
    print(" ")
    print(hexVal(hexF))
    print(" ")
    print(hexVal(hexaf))
    print(" ")
    print(hexVal(hexff))
    print(" ")
    print(hexVal(hexX))
    newline()
}
