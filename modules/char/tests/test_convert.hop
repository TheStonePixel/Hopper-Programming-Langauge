// EXPECT: upper: A Z A 1
// EXPECT: lower: a z a 1
// EXPECT: digitValue: 0 9 -1
// EXPECT: hexValue: 0 9 10 15 10 15 -1

import io from io
import char from char

entry main(int argc, address argv) {
    byte a   = cast 'a'
    byte zl  = cast 'z'
    byte A   = cast 'A'
    byte one = cast '1'

    print("upper: ")
    print(toUpper(a))
    print(" ")
    print(toUpper(zl))
    print(" ")
    print(toUpper(A))
    print(" ")
    print(toUpper(one))
    newline()

    print("lower: ")
    print(toLower(a))
    print(" ")
    print(toLower(zl))
    print(" ")
    print(toLower(A))
    print(" ")
    print(toLower(one))
    newline()

    byte zero = cast '0'
    byte nine = cast '9'
    byte bang = cast '!'
    print("digitValue: ")
    print(digitValue(zero))
    print(" ")
    print(digitValue(nine))
    print(" ")
    print(digitValue(bang))
    newline()

    byte hexA  = cast 'A'
    byte hexF  = cast 'F'
    byte hexaf = cast 'a'
    byte hexff = cast 'f'
    byte hexX  = cast 'X'
    print("hexValue: ")
    print(hexValue(zero))
    print(" ")
    print(hexValue(nine))
    print(" ")
    print(hexValue(hexA))
    print(" ")
    print(hexValue(hexF))
    print(" ")
    print(hexValue(hexaf))
    print(" ")
    print(hexValue(hexff))
    print(" ")
    print(hexValue(hexX))
    newline()
}
