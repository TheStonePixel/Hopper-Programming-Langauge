import io from linux
import sort from algo

extern function printf(String fmt, ...) int

function printArr(Array<int> arr) {
    printf("[")
    int i = 0
    while (i < arr.len()) {
        if (i > 0) { printf(", ") }
        printf("%d", arr.get(i))
        i = i + 1
    }
    printf("]\n")
}

entry main(int argc, address argv) {
    // ── insertion sort ────────────────────────────────────────────────────────
    Array<int> a = Array(8)
    a.push(5)
    a.push(2)
    a.push(8)
    a.push(1)
    a.push(9)
    a.push(3)

    insertionSort(a, ascending)
    printf("insertionSort asc: ")
    printArr(a)

    insertionSort(a, descending)
    printf("insertionSort desc: ")
    printArr(a)

    // ── quicksort ─────────────────────────────────────────────────────────────
    Array<int> b = Array(8)
    b.push(7)
    b.push(-2)
    b.push(4)
    b.push(0)
    b.push(-5)
    b.push(6)

    quickSort(b, ascending)
    printf("quickSort asc:  ")
    printArr(b)

    quickSort(b, descending)
    printf("quickSort desc: ")
    printArr(b)

    // ── merge sort ────────────────────────────────────────────────────────────
    Array<int> c = Array(8)
    c.push(3)
    c.push(1)
    c.push(4)
    c.push(1)
    c.push(5)
    c.push(9)
    c.push(2)
    c.push(6)

    mergeSort(c, ascending)
    printf("mergeSort asc:  ")
    printArr(c)

    mergeSort(c, descending)
    printf("mergeSort desc: ")
    printArr(c)

    // ── callback variable ─────────────────────────────────────────────────────
    callback cmp = ascending(int, int) bool
    Array<int> d = Array(4)
    d.push(10)
    d.push(3)
    d.push(7)
    d.push(1)

    quickSort(d, cmp)
    printf("quickSort via callback: ")
    printArr(d)

    printf("all sort tests passed\n")
}
