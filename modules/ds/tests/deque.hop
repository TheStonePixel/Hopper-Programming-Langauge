// TEST: constructor
// EXPECT: new() -> empty = 1
// EXPECT: new() -> len = 0

// TEST: pushBack / pushFront
// EXPECT: push(0,1,2,3) -> len = 4
// EXPECT: peekFront() = 0
// EXPECT: peekBack() = 3

// TEST: popFront / popBack
// EXPECT: popFront() = 0
// EXPECT: popBack() = 3
// EXPECT: pop() -> len = 2
// EXPECT: peekFront() = 1
// EXPECT: peekBack() = 2

// TEST: grow
// EXPECT: grow(16) -> len = 16
// EXPECT: grow(16) -> order preserved

import assert from core
import deque  from ds
extern function printf(String fmt, ...) int

entry main {
    Deque<int> d = Deque(4)

    assert(d.empty() == 1, "new deque should be empty\n")
    assert(d.len()   == 0, "new deque len should be 0\n")
    printf("new() -> empty = %lld\n", d.empty())
    printf("new() -> len = %lld\n", d.len())

    d.pushBack(1)
    d.pushBack(2)
    d.pushBack(3)
    d.pushFront(0)

    assert(d.len()       == 4, "len after 4 pushes\n")
    assert(d.peekFront() == 0, "peekFront wrong\n")
    assert(d.peekBack()  == 3, "peekBack wrong\n")
    printf("push(0,1,2,3) -> len = %lld\n", d.len())
    printf("peekFront() = %lld\n", d.peekFront())
    printf("peekBack() = %lld\n", d.peekBack())

    int v = d.popFront()
    assert(v == 0,        "popFront wrong\n")
    assert(d.len() == 3,  "len after popFront\n")
    printf("popFront() = %lld\n", v)

    v = d.popBack()
    assert(v == 3,        "popBack wrong\n")
    assert(d.len() == 2,  "len after popBack\n")
    printf("popBack() = %lld\n", v)
    printf("pop() -> len = %lld\n", d.len())

    assert(d.peekFront() == 1, "peekFront after pops\n")
    assert(d.peekBack()  == 2, "peekBack after pops\n")
    printf("peekFront() = %lld\n", d.peekFront())
    printf("peekBack() = %lld\n", d.peekBack())

    Deque<int> big = Deque(2)
    int i = 0
    while (i < 16) {
        big.pushBack(i)
        i = i + 1
    }
    assert(big.len() == 16, "grow: len wrong\n")
    printf("grow(16) -> len = %lld\n", big.len())

    assert(big.popFront() == 0,  "grow: front value\n")
    assert(big.popBack()  == 15, "grow: back value\n")
    printf("grow(16) -> order preserved\n")
}
