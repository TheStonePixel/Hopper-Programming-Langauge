// Tests String<byte> — growable byte string, no libc
// EXPECT: hello
// EXPECT: 42
// EXPECT: ff
// EXPECT: 0

import string from ds
import io from linux

entry main {
    String<byte> s = String(8)
    s.append(104)
    s.append(101)
    s.append(108)
    s.append(108)
    s.append(111)
    s.append(10)
    write(1, s.pointer(), s.length())

    String<byte> n = String(16)
    n.appendNumber(42)
    n.append(10)
    write(1, n.pointer(), n.length())

    String<byte> h = String(16)
    h.appendHex(255)
    h.append(10)
    write(1, h.pointer(), h.length())

    String<byte> z = String(4)
    z.appendNumber(0)
    z.append(10)
    write(1, z.pointer(), z.length())
}
