// TEST: constructor
// EXPECT: new() -> empty = 1
// EXPECT: new() -> len = 0

// TEST: push
// EXPECT: push(10, 20, 30) -> len = 3
// EXPECT: push(10, 20, 30) -> empty = 0

// TEST: peek
// EXPECT: peek() = 30
// EXPECT: peek() -> len unchanged = 3

// TEST: pop
// EXPECT: pop() = 30
// EXPECT: pop() = 20
// EXPECT: pop() -> len = 1
// EXPECT: pop() = 10
// EXPECT: pop() -> empty = 1

// TEST: grow
// EXPECT: grow(16) -> len = 16
// EXPECT: grow(16) -> values preserved

import assert from core
import stack  from ds
extern function printf(String fmt, ...) int

entry main {
    Stack<int> s = Stack(4)

    assert(s.empty() == 1, "new stack should be empty\n")
    assert(s.len()   == 0, "new stack len should be 0\n")
    printf("new() -> empty = %lld\n", s.empty())
    printf("new() -> len = %lld\n", s.len())

    s.push(10)
    s.push(20)
    s.push(30)

    assert(s.len()   == 3, "len after 3 pushes\n")
    assert(s.empty() == 0, "non-empty stack reports empty\n")
    printf("push(10, 20, 30) -> len = %lld\n", s.len())
    printf("push(10, 20, 30) -> empty = %lld\n", s.empty())

    assert(s.peek() == 30, "peek wrong\n")
    printf("peek() = %lld\n", s.peek())
    assert(s.len()  == 3,  "peek must not change len\n")
    printf("peek() -> len unchanged = %lld\n", s.len())

    int v = s.pop()
    assert(v == 30,       "first pop\n")
    assert(s.len() == 2,  "len after first pop\n")
    printf("pop() = %lld\n", v)

    v = s.pop()
    assert(v == 20,       "second pop\n")
    assert(s.len() == 1,  "len after second pop\n")
    printf("pop() = %lld\n", v)
    printf("pop() -> len = %lld\n", s.len())

    v = s.pop()
    assert(v == 10,        "third pop\n")
    assert(s.empty() == 1, "stack should be empty after drain\n")
    printf("pop() = %lld\n", v)
    printf("pop() -> empty = %lld\n", s.empty())

    Stack<int> big = Stack(2)
    int i = 0
    while (i < 16) {
        big.push(i)
        i = i + 1
    }
    assert(big.len() == 16, "grow: len wrong\n")
    printf("grow(16) -> len = %lld\n", big.len())

    assert(big.pop() == 15, "grow: top value\n")
    assert(big.pop() == 14, "grow: second value\n")
    printf("grow(16) -> values preserved\n")
}
