// EXPECT: empty = 1
// EXPECT: push 3 items
// EXPECT: len = 3
// EXPECT: peek = 30
// EXPECT: pop = 30
// EXPECT: pop = 20
// EXPECT: len = 1
// EXPECT: pop = 10
// EXPECT: empty = 1
// EXPECT: grow ok len = 16

import stack from ds
extern function printf(String fmt, ...) int

entry main {
    Stack<int> s = Stack(4)

    printf("empty = %lld\n", s.empty())
    printf("push 3 items\n")
    s.push(10)
    s.push(20)
    s.push(30)

    printf("len = %lld\n", s.len())
    printf("peek = %lld\n", s.peek())
    printf("pop = %lld\n", s.pop())
    printf("pop = %lld\n", s.pop())
    printf("len = %lld\n", s.len())
    printf("pop = %lld\n", s.pop())
    printf("empty = %lld\n", s.empty())

    Stack<int> big = Stack(2)
    int i = 0
    while (i < 16) {
        big.push(i)
        i = i + 1
    }
    printf("grow ok len = %lld\n", big.len())
}
