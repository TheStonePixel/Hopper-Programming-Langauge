// TEST: constructor
// EXPECT: new(4096) -> remaining = 4096

// TEST: alloc
// EXPECT: alloc(Point x2) -> remaining = 4064
// EXPECT: alloc(Point x2) -> both non-null = 1

// TEST: reset
// EXPECT: reset() -> remaining = 4096

import assert       from core
import bumpallocator from ds
extern function printf(String fmt, ...) int

struct Point {
    int x
    int y
}

entry main {
    byte pool[4096]
    BumpAllocator alloc = BumpAllocator(pool[0]::address, 4096)

    assert(alloc.remaining() == 4096, "initial remaining should be full capacity\n")
    printf("new(4096) -> remaining = %lld\n", alloc.remaining())

    address a = alloc.alloc(Point::size)
    address b = alloc.alloc(Point::size)

    assert(alloc.remaining() == 4064, "remaining after 2 Point allocs\n")
    printf("alloc(Point x2) -> remaining = %lld\n", alloc.remaining())

    assert(a != null, "first alloc should not be null\n")
    assert(b != null, "second alloc should not be null\n")
    int ok = 0
    if (a != null) {
        if (b != null) {
            ok = 1
        }
    }
    printf("alloc(Point x2) -> both non-null = %lld\n", ok)

    alloc.reset()
    assert(alloc.remaining() == 4096, "remaining after reset should be full\n")
    printf("reset() -> remaining = %lld\n", alloc.remaining())
}
