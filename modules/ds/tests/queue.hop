// TEST: constructor
// EXPECT: new() -> empty = 1
// EXPECT: new() -> len = 0

// TEST: push / pop
// EXPECT: push(1,2,3) -> len = 3
// EXPECT: peek() = 1
// EXPECT: pop() = 1
// EXPECT: pop() = 2
// EXPECT: pop() = 3
// EXPECT: pop() -> empty = 1

// TEST: peek
// EXPECT: peek() after repush = 10

// TEST: grow
// EXPECT: grow(16) -> len = 16
// EXPECT: grow(16) -> FIFO order preserved

import assert from core
import queue  from ds
extern function printf(String fmt, ...) int

entry main {
    Queue<int> q = Queue(4)

    assert(q.empty() == 1, "new queue should be empty\n")
    assert(q.len()   == 0, "new queue len should be 0\n")
    printf("new() -> empty = %lld\n", q.empty())
    printf("new() -> len = %lld\n", q.len())

    q.push(1)
    q.push(2)
    q.push(3)
    assert(q.len()   == 3, "len after 3 pushes\n")
    assert(q.peek()  == 1, "peek should be front\n")
    printf("push(1,2,3) -> len = %lld\n", q.len())
    printf("peek() = %lld\n", q.peek())

    int v = q.pop()
    assert(v == 1,         "first pop: FIFO order\n")
    assert(q.len() == 2,   "len after first pop\n")
    printf("pop() = %lld\n", v)

    v = q.pop()
    assert(v == 2, "second pop: FIFO order\n")
    printf("pop() = %lld\n", v)

    v = q.pop()
    assert(v == 3,          "third pop: FIFO order\n")
    assert(q.empty() == 1,  "queue should be empty after drain\n")
    printf("pop() = %lld\n", v)
    printf("pop() -> empty = %lld\n", q.empty())

    q.push(10)
    q.push(20)
    assert(q.peek() == 10, "peek after re-push\n")
    printf("peek() after repush = %lld\n", q.peek())

    Queue<int> big = Queue(2)
    int i = 0
    while (i < 16) {
        big.push(i)
        i = i + 1
    }
    assert(big.len() == 16, "grow: len wrong\n")
    printf("grow(16) -> len = %lld\n", big.len())

    assert(big.pop() == 0, "grow: FIFO order at 0\n")
    assert(big.pop() == 1, "grow: FIFO order at 1\n")
    assert(big.pop() == 2, "grow: FIFO order at 2\n")
    printf("grow(16) -> FIFO order preserved\n")
}
