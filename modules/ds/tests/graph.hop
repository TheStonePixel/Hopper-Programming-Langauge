// TEST: constructor
// EXPECT: new(4) -> degree(0) = 0
// EXPECT: new(4) -> hasEdge(0,1) = 0

// TEST: addEdge
// EXPECT: addEdge(0,1) -> hasEdge(0,1) = 1
// EXPECT: addEdge(0,2) -> hasEdge(0,2) = 1
// EXPECT: hasEdge(1,2) = 0
// EXPECT: directed: hasEdge(1,0) = 0
// EXPECT: degree(0) = 2
// EXPECT: degree(1) = 1
// EXPECT: degree(2) = 0

// TEST: removeEdge
// EXPECT: removeEdge(0,1) -> hasEdge(0,1) = 0
// EXPECT: removeEdge(0,1) -> hasEdge(0,2) = 1
// EXPECT: removeEdge(0,1) -> degree(0) = 1

import assert from core
import graph  from ds
extern function printf(String fmt, ...) int

entry main {
    Graph g = Graph(4)

    assert(g.hasEdge(0, 1) == 0, "no edges initially\n")
    assert(g.degree(0)     == 0, "degree 0 initially\n")
    printf("new(4) -> degree(0) = %lld\n", g.degree(0))
    printf("new(4) -> hasEdge(0,1) = %lld\n", g.hasEdge(0, 1))

    g.addEdge(0, 1)
    g.addEdge(0, 2)
    g.addEdge(1, 3)

    assert(g.hasEdge(0, 1) == 1, "edge 0->1 should exist\n")
    assert(g.hasEdge(0, 2) == 1, "edge 0->2 should exist\n")
    assert(g.hasEdge(1, 2) == 0, "edge 1->2 should not exist\n")
    assert(g.hasEdge(1, 0) == 0, "directed: 1->0 should not exist\n")
    assert(g.degree(0)     == 2, "degree of 0 should be 2\n")
    assert(g.degree(1)     == 1, "degree of 1 should be 1\n")
    assert(g.degree(2)     == 0, "degree of 2 should be 0\n")
    printf("addEdge(0,1) -> hasEdge(0,1) = %lld\n", g.hasEdge(0, 1))
    printf("addEdge(0,2) -> hasEdge(0,2) = %lld\n", g.hasEdge(0, 2))
    printf("hasEdge(1,2) = %lld\n", g.hasEdge(1, 2))
    printf("directed: hasEdge(1,0) = %lld\n", g.hasEdge(1, 0))
    printf("degree(0) = %lld\n", g.degree(0))
    printf("degree(1) = %lld\n", g.degree(1))
    printf("degree(2) = %lld\n", g.degree(2))

    g.removeEdge(0, 1)
    assert(g.hasEdge(0, 1) == 0, "edge 0->1 should be gone\n")
    assert(g.hasEdge(0, 2) == 1, "edge 0->2 should still exist\n")
    assert(g.degree(0)     == 1, "degree of 0 after remove\n")
    printf("removeEdge(0,1) -> hasEdge(0,1) = %lld\n", g.hasEdge(0, 1))
    printf("removeEdge(0,1) -> hasEdge(0,2) = %lld\n", g.hasEdge(0, 2))
    printf("removeEdge(0,1) -> degree(0) = %lld\n", g.degree(0))
}
