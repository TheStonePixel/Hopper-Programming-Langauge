// EXPECT: empty = 1
// EXPECT: peek = 50
// EXPECT: pop = 50
// EXPECT: pop = 40
// EXPECT: pop = 30
// EXPECT: pop = 20
// EXPECT: pop = 10
// EXPECT: empty = 1
// EXPECT: grow ok max = 15

import maxheap from ds
extern function printf(String fmt, ...) int

entry main {
    MaxHeap<int> h = MaxHeap(4)

    printf("empty = %lld\n", h.empty())

    h.push(30)
    h.push(10)
    h.push(50)
    h.push(20)
    h.push(40)

    printf("peek = %lld\n", h.peek())
    printf("pop = %lld\n", h.pop())
    printf("pop = %lld\n", h.pop())
    printf("pop = %lld\n", h.pop())
    printf("pop = %lld\n", h.pop())
    printf("pop = %lld\n", h.pop())
    printf("empty = %lld\n", h.empty())

    MaxHeap<int> big = MaxHeap(2)
    int i = 0
    while (i <= 15) {
        big.push(i)
        i = i + 1
    }
    printf("grow ok max = %lld\n", big.pop())
}
