// TEST: constructor
// EXPECT: new() -> empty = 1
// EXPECT: new() -> len = 0

// TEST: pushBack
// EXPECT: pushBack(1, 2, 3) -> len = 3
// EXPECT: pushBack(1, 2, 3) -> empty = 0
// EXPECT: peekFront() = 1
// EXPECT: peekBack() = 3

// TEST: popFront
// EXPECT: popFront() = 1
// EXPECT: popFront() = 2
// EXPECT: popFront() -> len = 1

// TEST: pushFront
// EXPECT: pushFront(0) -> len = 2
// EXPECT: peekFront() = 0
// EXPECT: peekBack() = 3

// TEST: drain
// EXPECT: drain() -> empty = 1

import assert     from core
import linkedlist from ds
extern function printf(String fmt, ...) int

entry main {
    LinkedList<int> list = LinkedList()

    assert(list.empty() == 1, "new list should be empty\n")
    assert(list.len()   == 0, "new list len should be 0\n")
    printf("new() -> empty = %lld\n", list.empty())
    printf("new() -> len = %lld\n", list.len())

    list.pushBack(1)
    list.pushBack(2)
    list.pushBack(3)

    assert(list.len()       == 3, "len after 3 pushBack\n")
    assert(list.empty()     == 0, "non-empty list reports empty\n")
    assert(list.peekFront() == 1, "peekFront wrong\n")
    assert(list.peekBack()  == 3, "peekBack wrong\n")
    printf("pushBack(1, 2, 3) -> len = %lld\n", list.len())
    printf("pushBack(1, 2, 3) -> empty = %lld\n", list.empty())
    printf("peekFront() = %lld\n", list.peekFront())
    printf("peekBack() = %lld\n", list.peekBack())

    int v = list.popFront()
    assert(v == 1,          "first popFront\n")
    assert(list.len() == 2, "len after first popFront\n")
    printf("popFront() = %lld\n", v)

    v = list.popFront()
    assert(v == 2,          "second popFront\n")
    assert(list.len() == 1, "len after second popFront\n")
    printf("popFront() = %lld\n", v)
    printf("popFront() -> len = %lld\n", list.len())

    list.pushFront(0)
    assert(list.len()       == 2, "len after pushFront\n")
    assert(list.peekFront() == 0, "peekFront after pushFront\n")
    assert(list.peekBack()  == 3, "peekBack after pushFront\n")
    printf("pushFront(0) -> len = %lld\n", list.len())
    printf("peekFront() = %lld\n", list.peekFront())
    printf("peekBack() = %lld\n", list.peekBack())

    list.popFront()
    list.popFront()
    assert(list.empty() == 1, "list should be empty after drain\n")
    assert(list.len()   == 0, "len should be 0 after drain\n")
    printf("drain() -> empty = %lld\n", list.empty())
}
