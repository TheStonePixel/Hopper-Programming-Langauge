// EXPECT: empty = 1
// EXPECT: peek = 10
// EXPECT: pop = 10
// EXPECT: pop = 20
// EXPECT: pop = 30
// EXPECT: pop = 40
// EXPECT: pop = 50
// EXPECT: empty = 1
// EXPECT: grow ok min = 0
// EXPECT: sorted order ok

import assert  from core
import minheap from ds
extern function printf(String fmt, ...) int

entry main {
    MinHeap<int> h = MinHeap(4)

    assert(h.empty() == 1, "new heap should be empty\n")
    assert(h.len()   == 0, "new heap len should be 0\n")
    printf("empty = %lld\n", h.empty())

    h.push(30)
    h.push(10)
    h.push(50)
    h.push(20)
    h.push(40)

    assert(h.len()  == 5,  "len after 5 pushes\n")
    assert(h.peek() == 10, "peek should return minimum\n")
    printf("peek = %lld\n", h.peek())

    int prev = h.pop()
    assert(prev == 10, "first pop\n")
    printf("pop = %lld\n", prev)

    int next = h.pop()
    assert(next == 20,     "second pop\n")
    assert(prev <= next,   "heap order: 10 <= 20\n")
    printf("pop = %lld\n", next)
    prev = next

    next = h.pop()
    assert(next == 30,     "third pop\n")
    assert(prev <= next,   "heap order: 20 <= 30\n")
    printf("pop = %lld\n", next)
    prev = next

    next = h.pop()
    assert(next == 40,     "fourth pop\n")
    assert(prev <= next,   "heap order: 30 <= 40\n")
    printf("pop = %lld\n", next)
    prev = next

    next = h.pop()
    assert(next == 50,     "fifth pop\n")
    assert(prev <= next,   "heap order: 40 <= 50\n")
    printf("pop = %lld\n", next)

    assert(h.empty() == 1, "heap should be empty after drain\n")
    printf("empty = %lld\n", h.empty())

    MinHeap<int> big = MinHeap(2)
    int i = 15
    while (i >= 0) {
        big.push(i)
        i = i - 1
    }
    assert(big.len() == 16, "grow: len wrong\n")
    int m = big.pop()
    assert(m == 0, "grow: min wrong\n")
    printf("grow ok min = %lld\n", m)

    prev = m
    int j = 1
    while (j < 16) {
        next = big.pop()
        assert(prev <= next, "grow: sorted order violated\n")
        prev = next
        j = j + 1
    }
    printf("sorted order ok\n")
}
