// EXPECT: empty = 1
// EXPECT: contains 5 = 1
// EXPECT: contains 3 = 1
// EXPECT: contains 7 = 1
// EXPECT: contains 4 = 0
// EXPECT: min = 1
// EXPECT: max = 9
// EXPECT: len = 5

import bst from ds
extern function printf(String fmt, ...) int

entry main {
    BST<int> tree = BST()

    printf("empty = %lld\n", tree.empty())
    tree.insert(5)
    tree.insert(3)
    tree.insert(7)
    tree.insert(1)
    tree.insert(9)

    printf("contains 5 = %lld\n", tree.contains(5))
    printf("contains 3 = %lld\n", tree.contains(3))
    printf("contains 7 = %lld\n", tree.contains(7))
    printf("contains 4 = %lld\n", tree.contains(4))
    printf("min = %lld\n", tree.min())
    printf("max = %lld\n", tree.max())
    printf("len = %lld\n", tree.len())
}
