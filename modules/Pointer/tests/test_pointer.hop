// EXPECT: get: 42
// EXPECT: set: 99
// EXPECT: ptr ok: true
// EXPECT: null check: false
// EXPECT: move: destination=77 source null=true
// EXPECT: swap: first=20 second=10
// EXPECT: destroy: null=true
// EXPECT: bool: true
// EXPECT: byte: 65

import io from io
import pointer from Pointer

entry main(int argc, address argv) {
    // Test 1: construct and get
    Pointer<int> pointer = Pointer(42)
    print("get: ")
    print(pointer.get())
    newline()

    // Test 2: set
    pointer.set(99)
    print("set: ")
    print(pointer.get())
    newline()

    // Test 3: ptr() returns non-null address
    address raw = pointer.ptr()
    bool ptrOk = raw != null
    print("ptr ok: ")
    print(ptrOk)
    newline()

    // Test 4: isNull() on live pointer
    print("null check: ")
    print(pointer.isNull())
    newline()

    // Test 5: move() — ownership transfer
    Pointer<int> source = Pointer(77)
    Pointer<int> destination = Pointer(0)
    source.move(destination)
    print("move: destination=")
    print(destination.get())
    print(" source null=")
    print(source.isNull())
    newline()

    // Test 6: swap()
    Pointer<int> first = Pointer(10)
    Pointer<int> second = Pointer(20)
    first.swap(second)
    print("swap: first=")
    print(first.get())
    print(" second=")
    print(second.get())
    newline()

    // Test 7: destroy() + double-destroy safety
    Pointer<int> dying = Pointer(55)
    dying.destroy()
    dying.destroy()
    print("destroy: null=")
    print(dying.isNull())
    newline()

    // Test 8: bool value
    Pointer<bool> flag = Pointer(true)
    print("bool: ")
    print(flag.get())
    newline()

    // Test 9: byte value
    byte letter = cast 65
    Pointer<byte> character = Pointer(letter)
    print("byte: ")
    byte stored = character.get()
    int asInt = cast stored
    print(asInt)
    newline()
}
