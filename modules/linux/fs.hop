// Linux file system — direct syscalls, no libc

const O_RDONLY = 0
const O_WRONLY = 1
const O_RDWR   = 2
const O_CREAT  = 64
const O_TRUNC  = 512
const O_APPEND = 1024

function open(string path, int flags, int mode) int {
    return syscall(2, path, flags, mode)
}

function close(int fd) int {
    return syscall(3, fd)
}
