}

function uart2_send_string(string s, int len) {
    int i = 0
    while (i < len) {
        uart2_send(s[i])
        i = i + 1
    }
}

function uart2_recv() byte {
    while (usart2_sr.rxne == 0) { }
    return usart2_dr.dr
}

function uart2_available() bool {
    return usart2_sr.rxne == 1
}

function uart2_flush() {
    while (usart2_sr.tc == 0) { }
}

function uart2_error() bool {
    return usart2_sr.ore == 1 || usart2_sr.fe == 1 || usart2_sr.ne == 1
}

function uart2_clear_errors() {
    bit dummy = usart2_sr.ore
    dummy = usart2_dr.dr
}


