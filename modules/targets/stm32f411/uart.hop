function uart6_init(int brr) {
    usart6_brr.mantissa = brr >> 4
    usart6_brr.fraction = brr & 0xF
    usart6_cr1.te = 1
    usart6_cr1.re = 1
    usart6_cr1.ue = 1
}

function uart6_send(byte b) {
    while (usart6_sr.txe == 0) { }
    usart6_dr.dr = b
}

function uart6_send_string(string s, int len) {
    int i = 0
    while (i < len) {
        uart6_send(s[i])
        i = i + 1
    }
}

function uart6_recv() byte {
    while (usart6_sr.rxne == 0) { }
    return usart6_dr.dr
}

function uart6_available() bool {
    return usart6_sr.rxne == 1
}

function uart6_flush() {
    while (usart6_sr.tc == 0) { }
}

function uart6_error() bool {
    return usart6_sr.ore == 1 || usart6_sr.fe == 1 || usart6_sr.ne == 1
}

function uart6_clear_errors() {
    bit dummy = usart6_sr.ore
    dummy = usart6_dr.dr
}
