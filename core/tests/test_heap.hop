// EXPECT: 4064
// EXPECT: 1
// EXPECT: 4096

import io from linux
import heap from datastructures

extern function printf(String fmt, ...) int

struct Point {
    int x
    int y
}

entry main {
    byte pool[4096]
    Heap heap = Heap(pool[0]::address, 4096)

    address a = heap.alloc(Point::size)
    address b = heap.alloc(Point::size)
    printf("%d\n", heap.remaining())

    int ok = 0
    if (a != null) {
        if (b != null) {
            ok = 1
        }
    }
    printf("%d\n", ok)

    heap.reset()
    printf("%d\n", heap.remaining())
}
