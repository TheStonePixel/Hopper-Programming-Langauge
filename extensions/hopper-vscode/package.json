{
    "name": "hopper-language",
    "displayName": "Hopper Language",
    "description": "Syntax highlighting for the Hopper programming language (.hop)",
    "version": "1.0.0",
    "engines": { "vscode": "^1.75.0" },
    "categories": ["Programming Languages"],
    "contributes": {
        "languages": [
            {
                "id": "hopper",
                "aliases": ["Hopper", "hop"],
                "extensions": [".hop"],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "hopper",
                "scopeName": "source.hopper",
                "path": "./syntaxes/hopper.tmLanguage.json"
            }
        ],
        "themes": [
            {
                "label": "Hopper Dark",
                "uiTheme": "vs-dark",
                "path": "./themes/hopper-dark.json"
            }
        ]
    }
}
