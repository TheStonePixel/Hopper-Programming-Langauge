{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Hopper",
    "scopeName": "source.hopper",
    "fileTypes": ["hop"],
    "patterns": [
        { "include": "#char-literals" }
    ],
    "repository": {
        "char-literals": {
            "patterns": [
                {
                    "name": "constant.character.hopper",
                    "match": "'\\\\.'"
                },
                {
                    "name": "constant.character.hopper",
                    "match": "'[^'\\\\]'"
                }
            ]
        }
    }
}
