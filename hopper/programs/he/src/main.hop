import Terminal from tui
import fs     from linux
import io     from linux
import Buffer from buffer
import Editor from editor

entry main(int argc, string[] argv) {
    Editor ed = Editor()
    if (argc >= 2) {
        string path = argv[1]
        ed.open_file(path)
    } else {
        ed.ensure_nonempty()
    }
    ed.run()
}
