{
  "name": "cat",
  "version": "0.1.0",
  "description": "concatenate and print files",
  "license": "MIT",
  "type": "executable",
  "entry": "src/main.hop",
  "dependencies": {
    "linux": "0.1.0",
    "x86_64": "0.1.0"
  },
  "targets": {
    "host": {
      "IO": {
        "for": "modules/linux/contracts/IO.hop",
        "use": "modules/x86_64/src/LinuxSyscalls.hop",
        "inline": true
      },
      "FileSystem": {
        "for": "modules/linux/contracts/FileSystem.hop",
        "use": "modules/x86_64/src/LinuxSyscalls.hop",
        "inline": true
      }
    }
  }
}
