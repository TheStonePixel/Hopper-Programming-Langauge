{
  "name": "regex",
  "version": "0.1.0",
  "description": "grep-like line search — regex flags, recursive, stdin, case-insensitive",
  "license": "MIT",
  "type": "executable",
  "entry": "src/main.hop",
  "dependencies": {
    "x86_64": "0.1.0"
  },
  "targets": {
    "host": {
      "Regex": {
        "from": "regex",
        "contract": "modules/regex/contracts/Regex.hop",
        "implementation": "modules/regex/src/Regex.hop"
      },
      "IO": {
        "from": "linux",
        "contract": "../../../modules/linux/contracts/IO.hop",
        "implementation": "modules/x86_64/src/LinuxSyscalls.hop",
        "inline": true
      },
      "FileSystem": {
        "from": "linux",
        "contract": "../../../modules/linux/contracts/FileSystem.hop",
        "implementation": "modules/x86_64/src/LinuxSyscalls.hop",
        "inline": true
      },
      "SIMD": {
        "from": "x86_64",
        "contract": "modules/x86_64/contracts/SIMD.hop",
        "implementation": "modules/x86_64/src/SIMD.hop"
      }
    }
  }
}
