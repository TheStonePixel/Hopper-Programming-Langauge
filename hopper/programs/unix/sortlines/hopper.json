{
  "name": "sortlines",
  "version": "0.1.0",
  "description": "sort lines of text",
  "license": "MIT",
  "type": "executable",
  "entry": "src/main.hop",
  "dependencies": {
    "linux": "0.1.0",
    "x86_64": "0.1.0"
  },
  "targets": {
    "host": {
      "IO": {
        "from": "linux",
        "interface": "modules/linux/interfaces/IO.hop",
        "implementation": "modules/x86_64/src/LinuxSyscalls.hop",
        "inline": true
      },
      "FileSystem": {
        "from": "linux",
        "interface": "modules/linux/interfaces/FileSystem.hop",
        "implementation": "modules/x86_64/src/LinuxSyscalls.hop",
        "inline": true
      },
      "SIMD": {
        "from": "compute",
        "interface": "modules/compute/interfaces/SIMD.hop",
        "implementation": "modules/x86_64/src/SIMD.hop",
        "inline": true
      }
    }
  }
}
