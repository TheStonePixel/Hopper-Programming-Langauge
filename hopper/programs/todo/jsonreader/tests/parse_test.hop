// Tests JSON parser: object, array, string, int, bool, null
// EXPECT: object (2 keys):
// EXPECT:   "x":
// EXPECT:     int: 42
// EXPECT:   "ok":
// EXPECT:     bool: true

import JSON from json

extern function printf(string fmt, ...) int
extern function strlen(string s) int

function indent(int depth) {
    int i = 0
    while (i < depth) {
        printf("  ")
        i = i + 1
    }
}

function printNode(JSON r, address nodePtr, int depth) {
    int kind = r.nodeKind(nodePtr)
    if (kind == JsonKind.NONE) {
        indent(depth)
        printf("null\n")
        return
    }
    if (kind == JsonKind.BOOL) {
        indent(depth)
        bool bv = r.nodeBool(nodePtr)
        if (bv) {
            printf("bool: true\n")
        } else {
            printf("bool: false\n")
        }
        return
    }
    if (kind == JsonKind.INT) {
        indent(depth)
        int n = r.nodeInt(nodePtr)
        printf("int: %lld\n", n)
        return
    }
    if (kind == JsonKind.STRING) {
        indent(depth)
        address sv = r.nodeStr(nodePtr)
        string ss = cast sv
        printf("string: \"%s\"\n", ss)
        return
    }
    if (kind == JsonKind.ARRAY) {
        indent(depth)
        int count = r.nodeLen(nodePtr)
        printf("array (%lld items):\n", count)
        address childBuf = r.nodeChildren(nodePtr)
        int i = 0
        while (i < count) {
            address slot = childBuf + i * 8
            address child = slot::value
            printNode(r, child, depth + 1)
            i = i + 1
        }
        return
    }
    if (kind == JsonKind.OBJECT) {
        indent(depth)
        int count = r.nodeLen(nodePtr)
        printf("object (%lld keys):\n", count)
        address childBuf = r.nodeChildren(nodePtr)
        address keyBuf   = r.nodeKeys(nodePtr)
        int i = 0
        while (i < count) {
            address kslot = keyBuf + i * 8
            address kptr = kslot::value
            string kstr = cast kptr
            indent(depth + 1)
            printf("\"%s\":\n", kstr)
            address cslot = childBuf + i * 8
            address child = cslot::value
            printNode(r, child, depth + 2)
            i = i + 1
        }
        return
    }
}

entry main {
    JSON r = JSON("", 0)
    string src = "{\"x\": 42, \"ok\": true}"
    int len = strlen(src)
    address src_addr = cast src
    address root = r.parse(src_addr, len)
    printNode(r, root, 0)
}
