{
  "name": "htop",
  "version": "0.1.0",
  "description": "Live process monitor — reads /proc and renders a terminal dashboard",
  "license": "MIT",
  "type": "executable",
  "entry": "htop.hop",
  "dependencies": {
    "linux": "0.1.0",
    "x86_64": "0.1.0",
    "ds": "0.1.0"
  },
  "use": {
    "IO": {
      "module": "linux",
      "interface": "modules/linux/contracts/IO.hop",
      "implementation": {
        "x86_64": "modules/x86_64/src/LinuxSyscalls.hop"
      }
    },
    "FileSystem": {
      "module": "linux",
      "interface": "modules/linux/contracts/FileSystem.hop",
      "implementation": {
        "x86_64": "modules/x86_64/src/LinuxSyscalls.hop"
      }
    },
    "System": {
      "module": "linux",
      "interface": "modules/linux/contracts/System.hop",
      "implementation": {
        "x86_64": "modules/x86_64/src/LinuxSyscalls.hop"
      }
    },
    "Array": {
      "module": "ds",
      "interface": "modules/ds/contracts/Array.hop",
      "implementation": "modules/ds/src/Array.hop"
    },
    "Map": {
      "module": "ds",
      "interface": "modules/ds/contracts/Map.hop",
      "implementation": "modules/ds/src/Map.hop"
    }
  }
}
