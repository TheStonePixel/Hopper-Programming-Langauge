{
  "name": "calc",
  "version": "0.1.0",
  "description": "RPN stack calculator — callback dispatch and higher-order folds",
  "license": "MIT",
  "type": "executable",
  "entry": "calc.hop",
  "dependencies": {
    "ds": "0.1.0",
    "math": "0.1.0"
  },
  "targets": {
    "host": {
      "Array": {
        "for": "modules/ds/contracts/Array.hop",
        "use": "modules/ds/src/Array.hop"
      },
      "Math": {
        "for": "modules/math/contracts/Math.hop",
        "use": "modules/math/src/Math.hop"
      }
    }
  }
}
