{
  "name": "pgrep",
  "version": "0.1.0",
  "description": "Parallel grep — searches files using regex, serialised output via mutex",
  "license": "Apache-2.0",
  "type": "executable",
  "entry": "pgrep.hop",
  "dependencies": {
    "regex": "0.1.0",
    "concurrent": "0.1.0",
    "linux": "0.1.0",
    "x86_64": "0.1.0"
  },
  "use": {
    "Regex": {
      "module": "regex",
      "interface": "modules/regex/contracts/Regex.hop",
      "implementation": "modules/regex/src/Regex.hop"
    },
    "Concurrent": {
      "module": "concurrent",
      "interface": "modules/concurrent/contracts/Concurrent.hop",
      "implementation": "modules/concurrent/src/Concurrent.hop"
    },
    "IO": {
      "module": "linux",
      "interface": "modules/linux/contracts/IO.hop",
      "implementation": {
        "x86_64": "modules/x86_64/src/LinuxSyscalls.hop"
      }
    },
    "FileSystem": {
      "module": "linux",
      "interface": "modules/linux/contracts/FileSystem.hop",
      "implementation": {
        "x86_64": "modules/x86_64/src/LinuxSyscalls.hop"
      }
    }
  }
}
