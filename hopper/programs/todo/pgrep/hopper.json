{
  "name": "pgrep",
  "version": "0.1.0",
  "description": "Parallel grep — searches files using regex, serialised output via mutex",
  "license": "Apache-2.0",
  "type": "executable",
  "entry": "pgrep.hop",
  "dependencies": {
    "regex": "0.1.0",
    "concurrent": "0.1.0",
    "linux": "0.1.0",
    "x86_64": "0.1.0"
  },
  "targets": {
    "host": {
      "Regex": {
        "for": "modules/regex/contracts/Regex.hop",
        "use": "modules/regex/src/Regex.hop"
      },
      "Concurrent": {
        "for": "modules/concurrent/contracts/Concurrent.hop",
        "use": "modules/concurrent/src/Concurrent.hop"
      },
      "IO": {
        "for": "modules/linux/contracts/IO.hop",
        "use": "modules/x86_64/src/LinuxSyscalls.hop",
        "inline": true
      },
      "FileSystem": {
        "for": "modules/linux/contracts/FileSystem.hop",
        "use": "modules/x86_64/src/LinuxSyscalls.hop",
        "inline": true
      }
    }
  }
}
