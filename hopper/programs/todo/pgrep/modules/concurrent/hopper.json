{
  "name": "concurrent",
  "version": "0.1.0",
  "description": "Concurrency primitives: Mutex and Condvar via SysV semaphores",
  "license": "MIT",
  "type": "library",
  "dependencies": {
    "arch": "0.1.0"
  },
  "exports": {
    "Mutex": {
      "for":      "interfaces/Concurrent.hop",
      "use": "src/Concurrent.hop"
    },
    "Condvar": {
      "for":      "interfaces/Concurrent.hop",
      "use": "src/Concurrent.hop"
    },
    "Concurrent": {
      "for":      "interfaces/Concurrent.hop",
      "use": "src/Concurrent.hop"
    }
  },
  "targets": {
    "host": {
      "Concurrent": {
        "for":      "interfaces/Concurrent.hop",
        "use": "src/Concurrent.hop"
      },
      "Core": {
        "for":      "../core/contracts/Core.hop",
        "use": "../core/src/Core.hop"
      }
    }
  }
}
