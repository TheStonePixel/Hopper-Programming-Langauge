{
  "name": "concurrent",
  "version": "0.1.0",
  "description": "Concurrency primitives: Mutex and Condvar via SysV semaphores",
  "license": "MIT",
  "type": "library",
  "dependencies": {
    "arch": "0.1.0"
  },
  "exports": {
    "Mutex": {
      "for": "interfaces/Concurrent.hop",
      "use": "src/Concurrent.hop"
    },
    "Condvar": {
      "for": "interfaces/Concurrent.hop",
      "use": "src/Concurrent.hop"
    },
    "Concurrent": {
      "for": "interfaces/Concurrent.hop",
      "use": "src/Concurrent.hop"
    }
  },
  "use": {
    "Concurrent": {
      "interface": "interfaces/Concurrent.hop",
      "implementation": "src/Concurrent.hop"
    },
    "Core": {
      "interface": "../core/contracts/Core.hop",
      "implementation": "../core/src/Core.hop"
    }
  }
}
