// Tests strategy pattern: swappable validators using callbacks
// EXPECT: isPositive: 4/7 pass
// EXPECT: isEven:     4/7 pass
// EXPECT: isNonZero:  6/7 pass

import Array from ds

extern function printf(string fmt, ...) int

function isPositive(int n) int {
    if (n > 0) { return 1 }
    return 0
}

function isEven(int n) int {
    if ((n % 2) == 0) { return 1 }
    return 0
}

function isNonZero(int n) int {
    if (n != 0) { return 1 }
    return 0
}

function countPassing(StandardArray nums, callback(int) int pred) int {
    int count = 0
    int i = 0
    while (i < nums.len()) {
        int v = cast<int>(nums.get(i))
        if (pred(v) == 1) {
            count = count + 1
        }
        i = i + 1
    }
    return count
}

entry main {
    StandardArray nums = StandardArray(8)
    address _n0 = cast<address>(-5)
    nums.push(_n0)
    address _n1 = cast<address>(0)
    nums.push(_n1)
    address _n2 = cast<address>(3)
    nums.push(_n2)
    address _n3 = cast<address>(8)
    nums.push(_n3)
    address _n4 = cast<address>(-2)
    nums.push(_n4)
    address _n5 = cast<address>(12)
    nums.push(_n5)
    address _n6 = cast<address>(7)
    nums.push(_n6)

    int n = nums.len()
    int pos = countPassing(nums, isPositive)
    int ev  = countPassing(nums, isEven)
    int nz  = countPassing(nums, isNonZero)
    printf("isPositive: %lld/%lld pass\n", pos, n)
    printf("isEven:     %lld/%lld pass\n", ev, n)
    printf("isNonZero:  %lld/%lld pass\n", nz, n)
}
