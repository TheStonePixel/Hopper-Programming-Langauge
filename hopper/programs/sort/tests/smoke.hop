// smoke test — verifies all three sort algorithms produce correct output
import io    from linux
import array from ds
import sort  from algo

extern function printf(String fmt, ...) int

entry main(int argc, address argv) {
    Array<int> a = Array(4)
    a.push(3)
    a.push(1)
    a.push(4)
    a.push(2)

    callback cmp = ascending(int, int) bool
    quickSort(a, cmp)

    bool ok = a.get(0) == 1 && a.get(1) == 2 && a.get(2) == 3 && a.get(3) == 4
    if (ok) {
        printf("sort: smoke test passed\n")
    }
}
