// Tests for-each loop over StandardArray
// EXPECT: 10
// EXPECT: 20
// EXPECT: 30
// EXPECT: sum: 60
import Array from ds

extern function printf(string fmt, ...) int

entry main {
    StandardArray nums = StandardArray(8)
    address _1 = cast 10
    nums.push(_1)
    address _2 = cast 20
    nums.push(_2)
    address _3 = cast 30
    nums.push(_3)

    for (int v : nums) {
        printf("%lld\n", v)
    }

    int sum = 0
    for (int n : nums) {
        sum = sum + n
    }
    printf("sum: %lld\n", sum)
}
