{
  "name": "pgrep",
  "version": "0.1.0",
  "description": "Parallel grep — searches files concurrently using regex and spawn()",
  "license": "Apache-2.0",
  "type": "executable",
  "entry": "pgrep.hop",
  "targets": {
    "host": {
      "Regex": {
        "from":           "regex",
        "interface":      "../../modules/regex/interfaces/Regex.hop",
        "implementation": "../../modules/regex/src/Regex.hop"
      },
      "Concurrent": {
        "from":           "concurrent",
        "interface":      "../../modules/concurrent/interfaces/Concurrent.hop",
        "implementation": "../../modules/concurrent/src/Concurrent.hop"
      },
      "IO": {
        "from":           "linux",
        "interface":      "../../modules/linux/interfaces/IO.hop",
        "implementation": "../../modules/linux/src/IO.hop"
      },
      "FileSystem": {
        "from":           "linux",
        "interface":      "../../modules/linux/interfaces/FileSystem.hop",
        "implementation": "../../modules/linux/src/FileSystem.hop"
      }
    }
  }
}
