// Tests OwnedBuffer: ptr, len, get, set, zero, resize
// EXPECT: PASS  len after construct
// EXPECT: PASS  set and get byte
// EXPECT: PASS  zero clears byte
// EXPECT: PASS  resize grows len
// EXPECT: PASS  resize preserves data
// EXPECT: buffer: 5 passed, 0 failed
import Core from core
import Buffer from pointer

entry main {
    TestSuite t = TestSuite("buffer")
    OwnedBuffer buf = OwnedBuffer(8)

    t.checkEq(buf.len(), 8, "len after construct")

    byte v = 42
    buf.set(3, v)
    byte got = buf.get(3)
    int goti = cast<int>(got)
    t.checkEq(goti, 42, "set and get byte")

    buf.zero()
    byte z = buf.get(3)
    int zi = cast<int>(z)
    t.checkEq(zi, 0, "zero clears byte")

    byte w = 99
    buf.set(0, w)
    buf.resize(16)
    t.checkEq(buf.len(), 16, "resize grows len")

    byte preserved = buf.get(0)
    int pi = cast<int>(preserved)
    t.checkEq(pi, 99, "resize preserves data")

    t.done()
}
