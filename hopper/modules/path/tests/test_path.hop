// EXPECT: abs: true
// EXPECT: len: 16
// EXPECT: base: baz.hop
// EXPECT: dir: /foo/bar
// EXPECT: ext: .hop
// EXPECT: rel: false
// EXPECT: rbase: main.hop
// EXPECT: rdir: src
// EXPECT: rext: .hop
// EXPECT: joined: /output/tokens.txt
// EXPECT: noext:
// EXPECT: rootdir: /
// EXPECT: hidden ext:

import io from core
import path from path

entry main(int argc, address argv) {
    // Absolute path: /foo/bar/baz.hop (16 bytes)
    Path p1 = Path("/foo/bar/baz.hop")
    print("abs: ")
    print(p1.isAbsolute())
    newline()
    print("len: ")
    print(p1.length())
    newline()
    Path bn = p1.basename()
    print("base: ")
    print(bn.str())
    newline()
    Path dn = p1.dirname()
    print("dir: ")
    print(dn.str())
    newline()
    Path ex = p1.ext()
    print("ext: ")
    print(ex.str())
    newline()

    // Relative path: src/main.hop
    Path p2 = Path("src/main.hop")
    print("rel: ")
    print(p2.isAbsolute())
    newline()
    Path rbn = p2.basename()
    print("rbase: ")
    print(rbn.str())
    newline()
    Path rdn = p2.dirname()
    print("rdir: ")
    print(rdn.str())
    newline()
    Path rex = p2.ext()
    print("rext: ")
    print(rex.str())
    newline()

    // join: /output + tokens.txt → /output/tokens.txt
    Path p3 = Path("/output")
    p3.join("tokens.txt")
    print("joined: ")
    print(p3.str())
    newline()

    // No extension: /etc/hosts
    Path p4 = Path("/etc/hosts")
    Path noex = p4.ext()
    print("noext: ")
    print(noex.str())
    newline()

    // Root-level file: /foo → dirname should be /
    Path p5 = Path("/foo")
    Path rootdn = p5.dirname()
    print("rootdir: ")
    print(rootdn.str())
    newline()

    // Hidden file: .bashrc → no extension (leading dot doesn't count)
    Path p6 = Path(".bashrc")
    Path hex = p6.ext()
    print("hidden ext: ")
    print(hex.str())
    newline()
}
