{
  "name": "path",
  "version": "0.1.0",
  "description": "Path manipulation: join, basename, dirname, ext",
  "license": "MIT",
  "type": "library",
  "dependencies": {},
  "exports": {
    "Path": {
      "interface":      "interfaces/Path.hop",
      "implementation": "src/Path.hop"
    }
  },
  "targets": {
    "host": {
      "Path": {
        "from":           "path",
        "interface":      "interfaces/Path.hop",
        "implementation": "src/Path.hop"
      },
      "Core": {
        "from":           "core",
        "interface":      "../core/interfaces/Core.hop",
        "implementation": "../core/src/Core.hop"
      }
    }
  }
}
