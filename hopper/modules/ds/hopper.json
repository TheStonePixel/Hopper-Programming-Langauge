{
  "name": "ds",
  "version": "0.1.0",
  "description": "Data structures: Array, Stack, Queue, Map, StringBuilder — address-based generics",
  "license": "MIT",
  "type": "library",
  "dependencies": {},
  "exports": {
    "Array": {
      "for":      "interfaces/Array.hop",
      "use": "src/Array.hop"
    },
    "Stack": {
      "for":      "interfaces/Stack.hop",
      "use": "src/Stack.hop"
    },
    "Queue": {
      "for":      "interfaces/Queue.hop",
      "use": "src/Queue.hop"
    },
    "Map": {
      "for":      "interfaces/Map.hop",
      "use": "src/Map.hop"
    },
    "StringBuilder": {
      "for":      "interfaces/StringBuilder.hop",
      "use": "src/StringBuilder.hop"
    }
  },
  "targets": {
    "host": {
      "Array": {
        "for":      "interfaces/Array.hop",
        "use": "src/Array.hop"
      },
      "Core": {
        "for":      "../core/contracts/Core.hop",
        "use": "../core/src/Core.hop"
      }
    }
  }
}
