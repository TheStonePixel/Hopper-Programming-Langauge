{
  "name": "tui",
  "version": "0.1.0",
  "description": "Terminal UI: raw mode, ANSI colors, box drawing, key input",
  "license": "MIT",
  "type": "library",
  "dependencies": {
    "arch": "0.1.0"
  },
  "exports": {
    "TUI": {
      "contract":      "interfaces/TUI.hop",
      "implementation": "src/TUI.hop"
    }
  },
  "targets": {
    "host": {
      "TUI": {
        "from":           "tui",
        "contract":      "interfaces/TUI.hop",
        "implementation": "src/TUI.hop"
      }
    }
  }
}
