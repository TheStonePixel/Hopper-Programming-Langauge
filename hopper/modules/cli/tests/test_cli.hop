// CLI integration tests — invoke `node kindling/hopper` via shellCapture.
//
// Fixture files are written with fileWrite (avoids shell quoting issues).
// All shell invocations go through shellCapture.

// TEST: help command
// EXPECT: PASS  help shows language name
// EXPECT: PASS  help shows flash command

// TEST: flash without board
// EXPECT: PASS  flash no-board error

// TEST: flash before build
// EXPECT: PASS  flash before-build error

// TEST: build missing file
// EXPECT: PASS  build missing file error

// TEST: flash unknown board
// EXPECT: PASS  flash unknown board error

// TEST: summary
// EXPECT: cli-tests: 6 passed, 0 failed

import shell from linux
import file  from io
import fs    from linux
import test  from core

// True if buf[0..len) contains needle.
function cliContains(address buf, int len, address needle) bool {
    int nLen = strLen(needle)
    if (nLen == 0) { return true }
    int i = 0
    while (i <= len - nLen) {
        bool match = true
        int j = 0
        while (j < nLen) {
            address hp = buf + i + j
            address np = needle + j
            byte hb = hp::value
            byte nb = np::value
            if (hb != nb) {
                match = false
                break
            }
            j = j + 1
        }
        if (match) { return true }
        i = i + 1
    }
    return false
}

// Append null-terminated string s into buf at *offset, advancing it.
function cliAppend(address buf, address offset, address s) {
    int cur = offset::value
    int i = 0
    while (true) {
        address sp = s + i
        byte b = sp::value
        int bi = cast b
        if (bi == 0) { break }
        address dp = buf + cur
        dp::value = b
        cur = cur + 1
        i = i + 1
    }
    offset::value = cur
}

// Null-terminate cmd at current offset.
function cliFinish(address buf, address offset) {
    int cur = offset::value
    address tp = buf + cur
    byte z = 0
    tp::value = z
}

// Run a shell command, discarding output (setup / teardown).
function shellRun(address cmd, address scratch) {
    shellCapture(cmd, scratch, 256)
}

// strlen for address (used internally).
function cliStrLen(address s) int {
    int n = 0
    while (true) {
        address p = s + n
        byte b = p::value
        int bi = cast b
        if (bi == 0) { return n }
        n = n + 1
    }
    return 0
}

entry main {
    // Absolute path to the Hopper repo root (cwd when test binary runs).
    address rootBuf = allocate 4096
    getcwd(rootBuf, 4095)

    // Absolute path to kindling/hopper script.
    address hopperPath = allocate 4096
    address off = allocate 8
    int z64 = 0
    off::value = z64
    cliAppend(hopperPath, off, rootBuf)
    cliAppend(hopperPath, off, "/kindling/hopper")
    cliFinish(hopperPath, off)

    address buf     = allocate 8192
    address scratch = allocate 256
    TestSuite t     = TestSuite("cli-tests")
    address cmd     = allocate 2048

    // ── setup ─────────────────────────────────────────────────────────────────
    shellRun("rm -rf /tmp/_hcli_nobrd /tmp/_hcli_pizero /tmp/_hcli_unkbrd", scratch)
    shellRun("mkdir -p /tmp/_hcli_nobrd /tmp/_hcli_pizero /tmp/_hcli_unkbrd", scratch)

    // Write hopper.json fixtures directly (avoids shell quoting issues).
    address jNoBrd = "{\"name\":\"nobrd\",\"version\":\"0.1.0\",\"type\":\"program\",\"main\":\"main.hop\"}"
    address jPiZero = "{\"name\":\"myboard\",\"board\":\"pi-zero\",\"version\":\"0.1.0\",\"type\":\"program\",\"main\":\"main.hop\"}"
    address jUnkBrd = "{\"name\":\"unkbrd\",\"board\":\"atmel-mega\",\"version\":\"0.1.0\",\"type\":\"program\",\"main\":\"main.hop\"}"

    fileWrite("/tmp/_hcli_nobrd/hopper.json",  jNoBrd,  cliStrLen(jNoBrd))
    fileWrite("/tmp/_hcli_pizero/hopper.json", jPiZero, cliStrLen(jPiZero))
    fileWrite("/tmp/_hcli_unkbrd/hopper.json", jUnkBrd, cliStrLen(jUnkBrd))

    // ── help ──────────────────────────────────────────────────────────────────
    int ov = 0
    off::value = ov
    cliAppend(cmd, off, "node '")
    cliAppend(cmd, off, hopperPath)
    cliAppend(cmd, off, "' help")
    cliFinish(cmd, off)
    int hn = shellCapture(cmd, buf, 8192)
    t.check(cliContains(buf, hn, "Hopper"), "help shows language name")
    t.check(cliContains(buf, hn, "flash"), "help shows flash command")

    // ── flash no-board ────────────────────────────────────────────────────────
    ov = 0
    off::value = ov
    cliAppend(cmd, off, "cd '/tmp/_hcli_nobrd' && node '")
    cliAppend(cmd, off, hopperPath)
    cliAppend(cmd, off, "' flash")
    cliFinish(cmd, off)
    int fn = shellCapture(cmd, buf, 8192)
    t.check(cliContains(buf, fn, "board"), "flash no-board error")

    // ── flash before build ────────────────────────────────────────────────────
    ov = 0
    off::value = ov
    cliAppend(cmd, off, "cd '/tmp/_hcli_pizero' && node '")
    cliAppend(cmd, off, hopperPath)
    cliAppend(cmd, off, "' flash")
    cliFinish(cmd, off)
    int fbn = shellCapture(cmd, buf, 8192)
    t.check(cliContains(buf, fbn, "kernel.img"), "flash before-build error")

    // ── build missing file ────────────────────────────────────────────────────
    ov = 0
    off::value = ov
    cliAppend(cmd, off, "cd '/tmp/_hcli_pizero' && node '")
    cliAppend(cmd, off, hopperPath)
    cliAppend(cmd, off, "' build no_such_file.hop")
    cliFinish(cmd, off)
    int bmn = shellCapture(cmd, buf, 8192)
    t.check(cliContains(buf, bmn, "not found"), "build missing file error")

    // ── flash unknown board ───────────────────────────────────────────────────
    ov = 0
    off::value = ov
    cliAppend(cmd, off, "cd '/tmp/_hcli_unkbrd' && node '")
    cliAppend(cmd, off, hopperPath)
    cliAppend(cmd, off, "' flash")
    cliFinish(cmd, off)
    int fun = shellCapture(cmd, buf, 8192)
    t.check(cliContains(buf, fun, "board"), "flash unknown board error")

    // ── teardown ─────────────────────────────────────────────────────────────
    shellRun("rm -rf /tmp/_hcli_nobrd /tmp/_hcli_pizero /tmp/_hcli_unkbrd", scratch)

    deallocate rootBuf
    deallocate hopperPath
    deallocate buf
    deallocate scratch
    deallocate cmd
    deallocate off

    t.done()
}
