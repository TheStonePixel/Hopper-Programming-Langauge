{
  "name": "io",
  "version": "0.1.0",
  "description": "File I/O: FileReader and FileWriter with open/close lifecycle",
  "license": "MIT",
  "type": "library",
  "dependencies": {
    "arch": "0.1.0"
  },
  "exports": {
    "FileReader": {
      "for": "interfaces/FileReader.hop",
      "use": "src/File.hop"
    },
    "FileWriter": {
      "for": "interfaces/FileWriter.hop",
      "use": "src/File.hop"
    }
  },
  "use": {
    "FileReader": {
      "interface": "interfaces/FileReader.hop",
      "implementation": {
        "x86_64": "src/File.hop"
      }
    },
    "FileWriter": {
      "interface": "interfaces/FileWriter.hop",
      "implementation": {
        "x86_64": "src/File.hop"
      }
    }
  }
}
