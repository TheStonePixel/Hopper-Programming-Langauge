{
  "name": "io",
  "version": "0.1.0",
  "description": "File I/O: FileReader and FileWriter with open/close lifecycle",
  "license": "MIT",
  "type": "library",
  "dependencies": {
    "arch": "0.1.0"
  },
  "exports": {
    "FileReader": {
      "contract":      "interfaces/FileReader.hop",
      "implementation": "src/File.hop"
    },
    "FileWriter": {
      "contract":      "interfaces/FileWriter.hop",
      "implementation": "src/File.hop"
    }
  },
  "targets": {
    "host": {
      "FileReader": {
        "from":           "io",
        "contract":      "interfaces/FileReader.hop",
        "implementation": "src/File.hop"
      },
      "FileWriter": {
        "from":           "io",
        "contract":      "interfaces/FileWriter.hop",
        "implementation": "src/File.hop"
      }
    }
  }
}
