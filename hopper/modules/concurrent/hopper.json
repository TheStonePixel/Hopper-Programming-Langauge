{
  "name": "concurrent",
  "version": "0.1.0",
  "description": "Concurrency primitives: Mutex and Condvar via SysV semaphores",
  "license": "MIT",
  "type": "library",
  "dependencies": {
    "arch": "0.1.0"
  },
  "exports": {
    "Mutex": {
      "interface":      "interfaces/Concurrent.hop",
      "implementation": "src/Concurrent.hop"
    },
    "Condvar": {
      "interface":      "interfaces/Concurrent.hop",
      "implementation": "src/Concurrent.hop"
    },
    "Concurrent": {
      "interface":      "interfaces/Concurrent.hop",
      "implementation": "src/Concurrent.hop"
    }
  },
  "targets": {
    "host": {
      "Concurrent": {
        "from":           "concurrent",
        "interface":      "interfaces/Concurrent.hop",
        "implementation": "src/Concurrent.hop"
      },
      "Core": {
        "from":           "core",
        "interface":      "../core/interfaces/Core.hop",
        "implementation": "../core/src/Core.hop"
      }
    }
  }
}
