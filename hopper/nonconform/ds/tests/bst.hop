// TEST: constructor
// EXPECT: new() -> empty = 1
// EXPECT: new() -> len = 0

// TEST: insert
// EXPECT: insert(5,3,7,1,9) -> len = 5
// EXPECT: insert(5,3,7,1,9) -> empty = 0

// TEST: contains
// EXPECT: contains(5) = 1
// EXPECT: contains(3) = 1
// EXPECT: contains(7) = 1
// EXPECT: contains(4) = 0
// EXPECT: contains(1) = 1
// EXPECT: contains(9) = 1

// TEST: min / max
// EXPECT: min() = 1
// EXPECT: max() = 9
// EXPECT: len() = 5

import assert from core
import bst    from ds
extern function printf(String fmt, ...) int

entry main {
    BST<int> tree = BST()

    assert(tree.empty() == 1, "new tree should be empty\n")
    assert(tree.len()   == 0, "new tree len should be 0\n")
    printf("new() -> empty = %lld\n", tree.empty())
    printf("new() -> len = %lld\n", tree.len())

    tree.insert(5)
    tree.insert(3)
    tree.insert(7)
    tree.insert(1)
    tree.insert(9)

    assert(tree.len()   == 5, "len after 5 inserts\n")
    assert(tree.empty() == 0, "non-empty tree reports empty\n")
    printf("insert(5,3,7,1,9) -> len = %lld\n", tree.len())
    printf("insert(5,3,7,1,9) -> empty = %lld\n", tree.empty())

    assert(tree.contains(5) == 1, "contains 5\n")
    assert(tree.contains(3) == 1, "contains 3\n")
    assert(tree.contains(7) == 1, "contains 7\n")
    assert(tree.contains(4) == 0, "should not contain 4\n")
    assert(tree.contains(1) == 1, "contains 1\n")
    assert(tree.contains(9) == 1, "contains 9\n")
    assert(tree.contains(0) == 0, "should not contain 0\n")
    assert(tree.contains(6) == 0, "should not contain 6\n")
    printf("contains(5) = %lld\n", tree.contains(5))
    printf("contains(3) = %lld\n", tree.contains(3))
    printf("contains(7) = %lld\n", tree.contains(7))
    printf("contains(4) = %lld\n", tree.contains(4))
    printf("contains(1) = %lld\n", tree.contains(1))
    printf("contains(9) = %lld\n", tree.contains(9))

    assert(tree.min() == 1, "min wrong\n")
    assert(tree.max() == 9, "max wrong\n")
    assert(tree.min() <= tree.max(), "min must be <= max\n")
    printf("min() = %lld\n", tree.min())
    printf("max() = %lld\n", tree.max())
    printf("len() = %lld\n", tree.len())
}
