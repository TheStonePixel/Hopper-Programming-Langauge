import io from linux
import shared from Pointer

extern function printf(String fmt, ...) int

entry main(int argc, address argv) {
    // Test 1: basic construction and access
    Shared<int> a = Shared(4)
    a.set(0, 10)
    a.set(1, 20)
    a.set(2, 30)
    a.set(3, 40)
    int rc1 = a.refCount()
    printf("refCount after create: %d\n", rc1)
    int v0 = a.get(0)
    int v3 = a.get(3)
    printf("a[0]=%d a[3]=%d\n", v0, v3)

    // Test 2: adopt — two owners of the same block
    Shared<int> b = Shared(0)
    int rcBefore = a.refCount()
    b.adopt(a.rawBlock(), a.len())
    int rcAfter = a.refCount()
    printf("refCount before adopt: %d  after: %d\n", rcBefore, rcAfter)

    // Test 3: writes via b are visible via a
    b.set(0, 999)
    int va = a.get(0)
    int vb = b.get(0)
    printf("a[0]=%d b[0]=%d (should both be 999)\n", va, vb)

    // Test 4: load / store (single-value sugar)
    Shared<int> sv = Shared(1)
    sv.store(777)
    int loaded = sv.load()
    printf("load/store: %d\n", loaded)

    // Test 5: byte shared buffer and zero()
    Shared<byte> buf = Shared(8)
    buf.set(0, 65)
    buf.set(1, 66)
    byte bv0 = buf.get(0)
    int bi0 = cast bv0
    printf("buf[0]=%d (should be 65)\n", bi0)
    buf.zero()
    byte bz = buf.get(0)
    int bzi = cast bz
    printf("after zero buf[0]=%d (should be 0)\n", bzi)

    // Test 6: ptr() address arithmetic
    Shared<int> p = Shared(2)
    p.set(0, 111)
    p.set(1, 222)
    address raw = p.ptr()
    int pv0 = raw::value
    printf("via ptr(): %d (should be 111)\n", pv0)

    printf("all tests passed\n")
}
