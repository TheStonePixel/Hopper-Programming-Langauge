// EXPECT: buf[0]=72 buf[1]=105
// EXPECT: nums: 100 200 300
// EXPECT: counter: 42
// EXPECT: after zero: buf[0]=0
// EXPECT: via ptr(): 99
// EXPECT: move: dst[0]=111 dst[1]=222 src.len=0
// EXPECT: swap: a[0]=333 b[0]=111 b[1]=222 b.len=2
// EXPECT: destroy: count=0
// EXPECT: all tests passed

import io from linux
import unique from Pointer

extern function printf(String fmt, ...) int

entry main(int argc, address argv) {
    // Test 1: byte buffer — get/set
    Unique<byte> buf = Unique(16)
    buf.set(0, 72)
    buf.set(1, 105)
    byte b0 = buf.get(0)
    byte b1 = buf.get(1)
    int i0 = cast b0
    int i1 = cast b1
    printf("buf[0]=%d buf[1]=%d\n", i0, i1)

    // Test 2: int array
    Unique<int> nums = Unique(8)
    nums.set(0, 100)
    nums.set(1, 200)
    nums.set(2, 300)
    int a = nums.get(0)
    int b = nums.get(1)
    int c = nums.get(2)
    printf("nums: %d %d %d\n", a, b, c)

    // Test 3: single-value load/store
    Unique<int> counter = Unique(1)
    counter.store(42)
    int v = counter.load()
    printf("counter: %d\n", v)

    // Test 4: zero fill
    buf.zero()
    byte z = buf.get(0)
    int zi = cast z
    printf("after zero: buf[0]=%d\n", zi)

    // Test 5: .ptr() for address operations
    Unique<int> val = Unique(1)
    val.store(0)
    address p = val.ptr()
    int pv = p::value
    pv = pv + 99
    p::value = pv
    printf("via ptr(): %d\n", val.load())

    // Test 6: move() — ownership transfer, no double-free
    Unique<int> src = Unique(2)
    src.set(0, 111)
    src.set(1, 222)
    Unique<int> dst = Unique(0)   // placeholder; move() frees this tiny alloc
    src.move(dst)
    int mv0 = dst.get(0)
    int mv1 = dst.get(1)
    int srcCount = src.len()
    printf("move: dst[0]=%d dst[1]=%d src.len=%d\n", mv0, mv1, srcCount)

    // Test 7: swap() — exchange ownership between two Unique<int>
    Unique<int> sa = Unique(2)
    sa.set(0, 111)
    sa.set(1, 222)
    Unique<int> sb = Unique(1)
    sb.set(0, 333)
    sa.swap(sb)
    int s0 = sa.get(0)
    int s1 = sb.get(0)
    int s2 = sb.get(1)
    int sbLen = sb.len()
    printf("swap: a[0]=%d b[0]=%d b[1]=%d b.len=%d\n", s0, s1, s2, sbLen)

    // Test 8: destroy() — free data, safe to call twice (deallocate null is no-op)
    Unique<byte> ud = Unique(16)
    byte udVal = cast 99
    ud.set(0, udVal)
    ud.destroy()
    int udCount = ud.len()
    ud.destroy()
    printf("destroy: count=%d\n", udCount)

    printf("all tests passed\n")
}
