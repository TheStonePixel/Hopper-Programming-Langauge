// TEST: basic lock / unlock
// EXPECT: lock ok
// EXPECT: unlock ok

// TEST: tryLock on unheld mutex
// EXPECT: tryLock unheld = 1

// TEST: four concurrent threads increment a shared counter under mutex
// EXPECT: counter = 4

// NOTE: We do NOT test tryLock-while-held: the default POSIX mutex
// (PTHREAD_MUTEX_NORMAL) deadlocks if the owner calls lock/tryLock again.

import concurrent from concurrent
import assert     from core
extern function printf(string fmt, ...) int

// pthread_mutex_lock and pthread_mutex_unlock are declared in concurrent.hop
// (via the import).  The worker calls them directly using the raw handle
// to avoid creating a second Mutex wrapper that would double-destroy.
extern function pthread_mutex_lock(address m) int
extern function pthread_mutex_unlock(address m) int

// Worker arg layout (16 bytes):
//   [0]  address mutHandle  — raw pthread_mutex_t address (from Mutex.rawHandle())
//   [8]  address counter    — heap-allocated shared int
function incrementWorker(address rawArgs) address {
    address mutHandle = rawArgs::value
    address cSlot     = rawArgs + 8
    address counter   = cSlot::value
    deallocate rawArgs

    pthread_mutex_lock(mutHandle)
    int val = counter::value
    val     = val + 1
    counter::value = val
    pthread_mutex_unlock(mutHandle)

    return null
}

entry main {
    Mutex mtx = Mutex()

    // ── basic lock / unlock ───────────────────────────────────────────────
    mtx.lock()
    printf("lock ok\n")
    mtx.unlock()
    printf("unlock ok\n")

    // ── tryLock on an unheld mutex ────────────────────────────────────────
    bool got = mtx.tryLock()
    assert(got == true, "tryLock on unheld mutex should succeed\n")
    printf("tryLock unheld = %lld\n", got)
    mtx.unlock()

    // ── four concurrent increments ────────────────────────────────────────
    address counter = allocate 8
    counter::value  = 0

    address wfn  = incrementWorker::address
    address mraw = mtx.rawHandle()

    address a1 = allocate 16
    address a2 = allocate 16
    address a3 = allocate 16
    address a4 = allocate 16

    a1::value           = mraw
    address a1c = a1 + 8
    a1c::value          = counter

    a2::value           = mraw
    address a2c = a2 + 8
    a2c::value          = counter

    a3::value           = mraw
    address a3c = a3 + 8
    a3c::value          = counter

    a4::value           = mraw
    address a4c = a4 + 8
    a4c::value          = counter

    Future<address> f1 = spawn(wfn, a1)
    Future<address> f2 = spawn(wfn, a2)
    Future<address> f3 = spawn(wfn, a3)
    Future<address> f4 = spawn(wfn, a4)

    f1.wait()
    f2.wait()
    f3.wait()
    f4.wait()

    int result = counter::value
    assert(result == 4, "mutex: counter should be 4\n")
    printf("counter = %lld\n", result)

    deallocate counter
}
