// Demonstrates what test failure output looks like.
// Subtraction is deliberately implemented as addition to produce wrong results.
// XFAIL

// TEST: addition (correct)
// EXPECT: add(1, 2) = 3
// EXPECT: add(0, 0) = 0
// EXPECT: add(-1, 1) = 0

// TEST: subtraction (deliberately wrong)
// EXPECT: sub(5, 3) = 2
// EXPECT: sub(10, 4) = 6
// EXPECT: sub(0, 1) = -1

extern function printf(string fmt, ...) int

entry main {
    printf("add(1, 2) = %lld\n", 1 + 2)
    printf("add(0, 0) = %lld\n", 0 + 0)
    printf("add(-1, 1) = %lld\n", -1 + 1)

    printf("sub(5, 3) = %lld\n",  5 + 3)
    printf("sub(10, 4) = %lld\n", 10 + 4)
    printf("sub(0, 1) = %lld\n",  0 + 1)
}
