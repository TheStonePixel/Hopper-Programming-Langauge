// Tests MMIO bitfield — memory-mapped hardware register access
// Field reads/writes generate volatile load/store + shift/mask automatically
// Compile only — no hardware to run against in tests

bitfield UartCR1 {
    pad 3
    bit te          // bit 3: transmitter enable
    bit re          // bit 4: receiver enable
    pad 8
    bit ue          // bit 13: USART enable
    pad 18
}

bitfield GpioModer {
    bit mode0[2]
    bit mode1[2]
    bit mode2[2]
    bit mode3[2]
    bit mode4[2]
    bit mode5[2]    // PA5 — LED on Nucleo boards
    bit mode6[2]
    bit mode7[2]
    pad 16
}

UartCR1  uart_cr1 @ 0x40013800
GpioModer gpioa   @ 0x48000000

entry main {
    // Enable UART, transmitter and receiver
    uart_cr1.ue = 1
    uart_cr1.te = 1
    uart_cr1.re = 1

    // Set PA5 to output mode (01)
    gpioa.mode5 = 1

    // Read back a field
    bit enabled = uart_cr1.ue
}
