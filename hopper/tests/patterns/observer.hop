// TEST: subscribe before set
// EXPECT: log:   0 -> 10
// EXPECT: audit: delta=10

// TEST: multiple handlers see the same event
// EXPECT: log:   10 -> 25
// EXPECT: audit: delta=15

// TEST: late subscriber only sees events after registration
// EXPECT: log:   25 -> 5
// EXPECT: audit: delta=-20
// EXPECT: alert: value is now 5

import array from ds

extern function printf(string fmt, ...) int

function onLog(int old, int next) int {
    printf("log:   %lld -> %lld\n", old, next)
    return 0
}

function onAudit(int old, int next) int {
    int delta = next - old
    printf("audit: delta=%lld\n", delta)
    return 0
}

function onAlert(int old, int next) int {
    printf("alert: value is now %lld\n", next)
    return 0
}

class Observable {
    int            value
    Array<address> listeners

    constructor(int initial) {
        self.value     = initial
        self.listeners = Array(8)
    }

    function subscribe(address handler) {
        self.listeners.push(handler)
    }

    function set(int newVal) {
        int old = self.value
        self.value = newVal
        int i = 0
        while (i < self.listeners.len()) {
            address fn = self.listeners.get(i)
            callback(int, int) int handler = cast fn
            handler(old, newVal)
            i = i + 1
        }
    }
}

entry main {
    Observable o = Observable(0)
    o.subscribe(onLog::address)
    o.subscribe(onAudit::address)
    o.set(10)
    o.set(25)
    o.subscribe(onAlert::address)
    o.set(5)
}
