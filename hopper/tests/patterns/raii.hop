// TEST: constructor fires on acquisition
// EXPECT: Buffer(64): acquired

// TEST: defer fires release on early return
// EXPECT: early return
// EXPECT: Buffer(64): released

// TEST: defer fires release on normal exit
// EXPECT: Buffer(64): acquired
// EXPECT: normal exit
// EXPECT: Buffer(64): released

// TEST: raw allocation with defer
// EXPECT: raw block in use
// EXPECT: returning

extern function printf(string fmt, ...) int

class Buffer {
    address data
    int     size

    constructor(int n) {
        self.data = allocate n
        self.size = n
        printf("Buffer(%lld): acquired\n", n)
    }

    function release() {
        printf("Buffer(%lld): released\n", self.size)
        deallocate self.data
    }
}

function freeBlock(address p) {
    deallocate p
}

function earlyExit() {
    Buffer buf = Buffer(64)
    defer buf.release()
    printf("early return\n")
    return
}

function normalExit() {
    Buffer buf = Buffer(64)
    defer buf.release()
    printf("normal exit\n")
}

function rawDemo() {
    address mem = allocate 128
    defer freeBlock(mem)
    printf("raw block in use\n")
    printf("returning\n")
}

entry main {
    earlyExit()
    normalExit()
    rawDemo()
}
