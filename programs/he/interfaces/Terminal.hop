interface Terminal {
    function init()
    function shutdown()
    function width() int
    function height() int
    function clear()
    function move(int row, int col)
    function write_str(string s)
    function write_byte(byte b)
    function read_key() int
    function hide_cursor()
    function show_cursor()
    function set_normal()
    function set_reverse()
}
